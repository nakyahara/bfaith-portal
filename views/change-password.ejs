<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>パスワード変更 - B-Faith Portal</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <header class="portal-header">
    <div class="header-left">
      <a href="/" class="back-link">← ダッシュボード</a>
      <h1>パスワード変更</h1>
    </div>
    <div class="header-right">
      <span class="user-name"><%= displayName %></span>
      <a href="/logout" class="btn-logout">ログアウト</a>
    </div>
  </header>

  <main class="admin-page">
    <% if (success) { %>
      <div class="success-msg">パスワードを変更しました。</div>
    <% } %>
    <% if (error) { %>
      <div class="error-msg"><%= error %></div>
    <% } %>

    <div class="form-card">
      <form method="POST" action="/change-password">
        <div class="form-group">
          <label for="currentPassword">現在のパスワード</label>
          <input type="password" id="currentPassword" name="currentPassword" required>
        </div>
        <div class="form-group">
          <label for="newPassword">新しいパスワード（6文字以上）</label>
          <input type="password" id="newPassword" name="newPassword" required minlength="6">
        </div>
        <div class="form-group">
          <label for="confirmPassword">新しいパスワード（確認）</label>
          <input type="password" id="confirmPassword" name="confirmPassword" required minlength="6">
        </div>
        <button type="submit" class="btn-save">変更する</button>
      </form>
    </div>
  </main>
</body>
</html>
