  <script>
    const BASE = '/apps/fba-replenishment';

    // 構成列のHTML生成
    function renderComponentCell(r) {
      const comps = r.set_components;
      if (!comps || comps.length === 0) {
        // componentsなし → NE商品コードだけ表示
        return `<td class="comp-cell">${r.ne_code || '-'}</td>`;
      }
      if (comps.length === 1 && (comps[0].qty || 1) === 1) {
        // 単品×1 → シンプル表示
        return `<td class="comp-cell">${comps[0].ne_code}</td>`;
      }
      if (comps.length === 1) {
        // 単品×N → 数量表示
        return `<td class="comp-cell"><span class="comp-tag">${comps[0].ne_code} ×${comps[0].qty}</span></td>`;
      }
      // 複数構成 → アコーディオン
      const id = 'comp_' + r.amazon_sku.replace(/[^a-zA-Z0-9]/g, '_');
      const summary = `${comps.length}種`;
      const details = comps.map(c => `<span class="comp-tag">${c.ne_code} ×${c.qty}</span>`).join(' ');
      return `<td class="comp-cell">
        <span class="comp-toggle" onclick="document.getElementById('${id}').classList.toggle('open')">${summary} ▸</span>
        <div class="comp-detail" id="${id}">${details}</div>
      </td>`;
    }

    function log(msg) {
      const el = document.getElementById('log');
      const ts = new Date().toLocaleTimeString('ja-JP');
      el.textContent += `\n[${ts}] ${msg}`;
      el.scrollTop = el.scrollHeight;
    }

    async function loadStatus() {
      try {
        const res = await fetch(`${BASE}/api/status`);
        const d = await res.json();
        document.getElementById('lastFetch').textContent = d.latestSnapshotDate || '-';
        document.getElementById('skuCount').textContent = d.snapshotCount || 0;
        document.getElementById('mappingCount').textContent = d.mappingCount || 0;
        document.getElementById('warehouseCount').textContent = d.warehouseProducts ? `${d.warehouseProducts}商品` : '-';
        document.getElementById('fetchStatus').textContent = d.fetchInProgress ? '取得中...' : '待機中';
        if (d.snapshotCount > 0) loadSnapshots();
      } catch (e) { log('ステータス取得エラー: ' + e.message); }
    }

    let skuMappingMap = {}; // SKU→ASIN等のマッピング
    let warehouseSummaryMap = {}; // 商品コード→倉庫サマリー

    async function loadSkuMappingMap() {
      try {
        const res = await fetch(`${BASE}/api/sku-mappings`);
        const mappings = await res.json();
        skuMappingMap = {};
        for (const m of mappings) skuMappingMap[m.amazon_sku] = m;
      } catch(e) { /* 無視 */ }
    }

    async function loadWarehouseSummaryMap() {
      try {
        const res = await fetch(`${BASE}/api/warehouse/summary`);
        const data = await res.json();
        warehouseSummaryMap = {};
        for (const w of data) warehouseSummaryMap[w.logizard_code] = w;
      } catch(e) { /* 無視 */ }
    }

    async function loadSnapshots() {
      try {
        const res = await fetch(`${BASE}/api/snapshots/latest`);
        const d = await res.json();
        snapshotData = d.data || [];
        // ASINを紐付け
        if (Object.keys(skuMappingMap).length === 0) await loadSkuMappingMap();
        for (const s of snapshotData) {
          if (!s.asin && skuMappingMap[s.amazon_sku]) s.asin = skuMappingMap[s.amazon_sku].asin;
        }
        if (sortKey) {
          sortAndRender();
        } else {
          renderSnapshot(snapshotData);
        }
      } catch (e) { log('スナップショット読込エラー: ' + e.message); }
    }

    // ソート機能
    let snapshotData = [];
    let sortKey = null;
    let sortDir = 'asc';

    function sortAndRender() {
      if (!sortKey || !snapshotData.length) return;
      const th = document.querySelector(`th[data-key="${sortKey}"]`);
      const isNum = th?.dataset.type === 'num';

      snapshotData.sort((a, b) => {
        let va = a[sortKey], vb = b[sortKey];
        if (isNum) {
          va = parseFloat(va) || 0;
          vb = parseFloat(vb) || 0;
        } else {
          va = String(va || '');
          vb = String(vb || '');
        }
        if (va < vb) return sortDir === 'asc' ? -1 : 1;
        if (va > vb) return sortDir === 'asc' ? 1 : -1;
        return 0;
      });
      renderSnapshot(snapshotData);
    }

    function renderSnapshot(data) {
      const tbody = document.getElementById('snapshotBody');
      if (!data || data.length === 0) {
        tbody.innerHTML = '<tr><td colspan="12">データなし</td></tr>';
        return;
      }
      const snapDate = data[0]?.snapshot_date;
      tbody.innerHTML = data.map(r => {
        const w = r.fba_inbound_working || 0;
        let workingHtml = String(w);
        if (w > 0 && r.working_first_seen) {
          const days = Math.floor((new Date(snapDate || new Date()) - new Date(r.working_first_seen)) / 86400000);
          const cls = days >= 7 ? 'working-expired' : days >= 4 ? 'working-warn' : 'working-fresh';
          workingHtml = `<span class="${cls}">${w}</span> <span class="working-days">${days}日</span>`;
        }
        return `<tr>
          <td>${r.amazon_sku}</td>
          <td class="product-name" title="${r.product_name || ''}">${r.asin ? `<a href="https://www.amazon.co.jp/dp/${r.asin}" target="_blank" style="color:inherit;text-decoration:none;" title="Amazonで開く">${r.product_name || ''}</a>` : (r.product_name || '')}</td>
          <td>${r.fba_available}</td>
          <td>${workingHtml}</td>
          <td>${r.fba_inbound_shipped || 0}</td>
          <td>${r.fba_inbound_received || 0}</td>
          <td>${r.days_of_supply || '-'}</td>
          <td>${r.units_sold_7d}</td>
          <td>${r.units_sold_30d}</td>
          <td>${r.sales_rank || '-'}</td>
          <td>${r.your_price ? '¥' + Number(r.your_price).toLocaleString() : '-'}</td>
          <td>${r.featured_offer_price ? '¥' + Number(r.featured_offer_price).toLocaleString() : '-'}</td>
        </tr>`;
      }).join('');
    }

    async function fetchReports() {
      if (!confirm('SP-APIレポートを取得します。完了後「復元して表示」で作業状態を戻せます。よろしいですか？')) return;
      const btn = document.getElementById('btnFetchAll');
      btn.disabled = true;
      btn.innerHTML = '<span class="spinner"></span>取得中...';
      log('SP-API 3レポート取得開始...(最大5分かかります)');

      try {
        const res = await fetch(`${BASE}/api/fetch-reports`, { method: 'POST' });
        const d = await res.json();
        if (d.error) { log('エラー: ' + d.error); return; }
        log(`完了! PLANNING: ${d.planning.count}件, RESTOCK: ${d.restock.count}件, INVENTORY: ${d.inventory.count}件`);
        if (d.errors.length > 0) {
          d.errors.forEach(e => log(`警告: ${e.report} - ${e.error}`));
        }
        loadStatus();
        completeStep(1);
        // データ取得後もドラフトは保持（復元ボタンで戻せる）
      } catch (e) { log('エラー: ' + e.message); }
      finally {
        btn.disabled = false;
        btn.textContent = 'SP-APIレポート全取得';
      }
    }

    async function uploadCsv(input) {
      if (!input.files[0]) return;

      // SP-APIデータが今日の日付か確認
      const today = new Date().toISOString().slice(0, 10);
      const snapDate = document.getElementById('lastFetch').textContent.trim();
      if (snapDate && snapDate !== today) {
        const ok = confirm(`SP-APIデータの日付が「${snapDate}」です（今日は${today}）。\nデータが古い可能性があります。このまま続けますか？`);
        if (!ok) { input.value = ''; return; }
      }

      const form = new FormData();
      form.append('csv', input.files[0]);
      log(`CSVアップロード中: ${input.files[0].name}`);

      try {
        const res = await fetch(`${BASE}/api/warehouse/upload`, { method: 'POST', body: form });
        const d = await res.json();
        if (d.error) { log('エラー: ' + d.error); return; }
        const s = d.summary || {};
        log(`完了! ${d.count}行取込 / ${s.uniqueProducts || '?'}商品 / 倉庫在庫: ${s.totalQty || '?'}個 / Yロケ(施設): ${s.yLocationProducts || 0}商品 ${s.yLocationQty || 0}個`);
        completeStep(2);
      } catch (e) { log('エラー: ' + e.message); }
      input.value = '';
    }

    // ===== 推奨リスト =====
    let recData = [];
    let recSortKey = 'urgency_score';
    let recSortDir = 'desc';

    let recMeta = {}; // APIレスポンスのメタ情報
    let manualItems = []; // 手動追加アイテム

    async function calcRecommendations() {
      if (!confirm('推奨リストを再計算します。完了後「復元して表示」で作業状態を戻せます。よろしいですか？')) return;
      const btn = document.getElementById('btnCalc');
      btn.disabled = true;
      btn.innerHTML = '<span class="spinner"></span>計算中...';
      log('推奨リスト生成中...');

      // ドラフトは保持（復元ボタンで戻せる）
      selectedSkus.clear();
      Object.keys(shipQtyMap).forEach(k => delete shipQtyMap[k]);

      try {
        const res = await fetch(`${BASE}/api/recommendations?debug=1`);
        const d = await res.json();
        if (d.error) { log('エラー: ' + d.error); return; }
        if (d.errors && d.errors.length) { d.errors.forEach(e => log('警告: ' + e)); }
        recData = d.items || [];
        recMeta = d;
        manualItems = [];
        log(`完了! 全${d.total_skus}SKU / 推奨${d.recommended_skus}SKU / 合計${d.recommended_units}個`);
        document.getElementById('recSection').style.display = '';
        updateRecSummary();
        filterRecList();
        updateOrderList();
        updateStockoutList();
        await loadWarehouseSummaryMap();
        await updateNewProductList();
        // ドラフトがあれば復元バナーを表示
        await checkDraftOnLoad();
      } catch (e) { log('エラー: ' + e.message); }
      finally {
        btn.disabled = false;
        btn.textContent = '推奨リスト生成';
      }
    }

    // 選択管理
    const selectedSkus = new Set();
    const shipQtyMap = {}; // SKU→手動変更した納品数量

    function updateRecSummary() {
      // 全体
      document.getElementById('recSkus').textContent = (recMeta.recommended_skus || 0) + ' SKU';
      document.getElementById('recUnits').textContent = (recMeta.recommended_units || 0).toLocaleString() + ' 個';
      document.getElementById('totalSkus').textContent = recMeta.total_skus || 0;
      document.getElementById('snapshotDateDisp').textContent = recMeta.snapshot_date || '-';

      // 赤/黄の内訳
      const allRec = [...recData.filter(r => r.recommended_qty > 0), ...manualItems];
      const redItems = allRec.filter(r => r.urgency_score >= 80);
      const yellowItems = allRec.filter(r => r.urgency_score >= 40 && r.urgency_score < 80);
      document.getElementById('recRedSkus').textContent = redItems.length + ' SKU';
      document.getElementById('recRedUnits').textContent = redItems.reduce((s, r) => s + (r.recommended_qty || 0), 0).toLocaleString() + ' 個';
      document.getElementById('recYellowSkus').textContent = yellowItems.length + ' SKU';
      document.getElementById('recYellowUnits').textContent = yellowItems.reduce((s, r) => s + (r.recommended_qty || 0), 0).toLocaleString() + ' 個';

      updateSelectedCount();
    }

    function updateSelectedCount() {
      let count = 0, units = 0;
      document.querySelectorAll('.rec-check:checked').forEach(cb => {
        count++;
        const sku = cb.dataset.sku;
        // 納品数量入力値を優先、なければ補正後の値
        const qtyInput = document.querySelector(`.ship-qty-input[data-sku="${sku}"]`);
        units += parseInt(qtyInput?.value || cb.dataset.qty) || 0;
      });
      document.getElementById('selectedCount').textContent = count + ' SKU';
      document.getElementById('selectedUnits').textContent = units.toLocaleString() + ' 個';
    }

    function onShipQtyChange(input) {
      const sku = input.dataset.sku;
      const val = parseInt(input.value) || 0;
      const item = recData.find(r => r.amazon_sku === sku);
      const defaultVal = item?.adjusted_qty || 0;
      // 変更されたかどうかでスタイル切り替え
      if (val !== defaultVal) {
        shipQtyMap[sku] = val;
        input.style.background = '#fef3c7';
        input.style.borderColor = '#d97706';
        input.style.fontWeight = 'bold';
      } else {
        delete shipQtyMap[sku];
        input.style.background = '';
        input.style.borderColor = '#d1d5db';
        input.style.fontWeight = '';
      }
      updateSelectedCount();
      scheduleAutoSave();
    }

    function onCheckChange(cb) {
      if (cb.checked) {
        selectedSkus.add(cb.dataset.sku);
      } else {
        selectedSkus.delete(cb.dataset.sku);
      }
      updateSelectedCount();
      scheduleAutoSave();
    }

    function checkAllRed() {
      document.querySelectorAll('.rec-check[data-urg="red"]').forEach(cb => {
        cb.checked = true;
        selectedSkus.add(cb.dataset.sku);
      });
      updateSelectedCount();
      scheduleAutoSave();
    }

    function uncheckAll() {
      document.querySelectorAll('.rec-check').forEach(cb => {
        cb.checked = false;
      });
      selectedSkus.clear();
      updateSelectedCount();
      scheduleAutoSave();
    }

    function filterRecList() {
      const mode = document.querySelector('input[name="recFilter"]:checked')?.value || 'recommended';
      const searchQuery = (document.getElementById('recSearch')?.value || '').trim().toLowerCase();
      let filtered = recData;
      // 検索中は全SKUから検索（推奨のみフィルターをバイパス）
      if (!searchQuery && mode === 'recommended') filtered = filtered.filter(r => r.recommended_qty > 0 || r._manual);
      // 検索フィルター
      if (searchQuery) {
        filtered = filtered.filter(r =>
          (r.product_name || '').toLowerCase().includes(searchQuery) ||
          (r.amazon_sku || '').toLowerCase().includes(searchQuery) ||
          (r.ne_code || '').toLowerCase().includes(searchQuery)
        );
      }
      // 手動追加アイテムを先頭に含める
      const combined = [...manualItems.filter(m => !filtered.find(r => r.amazon_sku === m.amazon_sku)), ...filtered];
      renderRecList(combined);
      document.getElementById('recFilterCount').textContent = `表示: ${combined.length} 件`;

      syncSnapshotSearch(searchQuery);
    }

    // スナップショットテーブルを検索語で連動フィルター（全タブ共通）
    function syncSnapshotSearch(query) {
      if (query) {
        const filteredSnap = snapshotData.filter(r =>
          (r.product_name || '').toLowerCase().includes(query) ||
          (r.amazon_sku || '').toLowerCase().includes(query)
        );
        renderSnapshot(filteredSnap);
      } else {
        renderSnapshot(snapshotData);
      }
    }

    function addManualItem() {
      const skuInput = document.getElementById('manualSku');
      const qtyInput = document.getElementById('manualQty');
      const msgEl = document.getElementById('manualMsg');
      const sku = skuInput.value.trim();
      const qty = parseInt(qtyInput.value) || 0;
      if (!sku) { msgEl.textContent = 'SKUを入力してください'; return; }
      if (qty <= 0) { msgEl.textContent = '数量を入力してください'; return; }

      // 既存データから探す
      const existing = recData.find(r => r.amazon_sku === sku);
      if (existing) {
        existing.recommended_qty = qty;
        existing.is_today = true;
        existing._manual = true;
        msgEl.textContent = `${sku} の推奨数を ${qty} に設定しました`;
      } else {
        // データにないSKUでも手動追加
        const item = {
          amazon_sku: sku,
          asin: '',
          product_name: '(手動追加)',
          fba_available: '-',
          effective_fba_stock: '-',
          days_of_supply: '-',
          reorder_point: '-',
          raw_needed: '-',
          target_days: '-',
          units_sold_30d: '-',
          warehouse_raw: '-',
          warehouse_available: '-',
          recommended_qty: qty,
          urgency_score: 999,
          alerts: [],
          is_today: true,
          _manual: true,
        };
        manualItems.push(item);
        msgEl.textContent = `${sku} を ${qty} 個で追加しました`;
      }
      skuInput.value = '';
      qtyInput.value = '';
      filterRecList();
      // サマリー更新（手動追加を含む）
      const allRec = [...recData.filter(r => r.recommended_qty > 0), ...manualItems];
      recMeta.recommended_skus = allRec.length;
      recMeta.recommended_units = allRec.reduce((s, i) => s + (i.recommended_qty || 0), 0);
      updateRecSummary();
    }

    function renderRecList(data) {
      const tbody = document.getElementById('recBody');
      if (!data.length) { tbody.innerHTML = '<tr><td colspan="23">該当なし</td></tr>'; return; }

      // ソート
      data.sort((a, b) => {
        // 他タブから追加されたアイテムは常に先頭
        const aAdded = a._fromStockout || a._fromNewProduct ? 1 : 0;
        const bAdded = b._fromStockout || b._fromNewProduct ? 1 : 0;
        if (aAdded !== bAdded) return bAdded - aAdded;

        const th = document.querySelector(`th.sortable-rec[data-key="${recSortKey}"]`);
        const isNum = th?.dataset.type === 'num';
        let va = a[recSortKey], vb = b[recSortKey];
        if (isNum) { va = parseFloat(va) || 0; vb = parseFloat(vb) || 0; }
        else { va = String(va || ''); vb = String(vb || ''); }
        if (va < vb) return recSortDir === 'asc' ? -1 : 1;
        if (va > vb) return recSortDir === 'asc' ? 1 : -1;
        return 0;
      });

      // グループ内ナンバリング用カウンター
      let redNum = 0, yellowNum = 0, whiteNum = 0;

      tbody.innerHTML = data.map(r => {
        const urgCls = r.urgency_score >= 80 ? 'urgency-high' : r.urgency_score >= 40 ? 'urgency-mid' : '';
        const manualCls = r._manual ? 'style="background:#eff6ff;"' : '';
        let alertsHtml = (r.alerts || []).map(a =>
          `<span class="alert-badge alert-${a.level}" title="${a.message}">${a.type === 'cart_block' ? '🔴' : a.type === 'missing' ? '🔴' : a.level === 2 ? '⚠' : 'ℹ'} ${a.message.slice(0,15)}</span>`
        ).join('');
        if (r.expiry_limited) {
          alertsHtml += `<span class="alert-badge alert-2" title="有効期限制限: ${r.expiry_date} 同一期限${r.expiry_same_qty}個">⚠ 期限制限${r.expiry_same_qty}個</span>`;
        }
        if (r._planCreated) {
          alertsHtml += `<span class="alert-badge" style="background:#dcfce7;color:#16a34a;font-weight:bold;">プラン作成済み ✅</span>`;
        }
        const dosVal = r.days_of_supply;
        const dosColor = typeof dosVal === 'number' && dosVal < 7 ? 'color:#dc2626;font-weight:bold' : typeof dosVal === 'number' && dosVal < 14 ? 'color:#d97706' : '';
        const reorderVal = r.reorder_point;
        const belowReorder = typeof r.effective_fba_stock === 'number' && typeof reorderVal === 'number' && r.effective_fba_stock < reorderVal;
        // ナンバリング
        let rowNum = '';
        if (r._fromNewProduct) { rowNum = '新規'; }
        else if (r._fromStockout) { rowNum = '欠品'; }
        else if (r._manual) { rowNum = '手動'; }
        else if (r.urgency_score >= 80) { redNum++; rowNum = `🔴${redNum}`; }
        else if (r.urgency_score >= 40) { yellowNum++; rowNum = `🟡${yellowNum}`; }
        else { whiteNum++; rowNum = `${whiteNum}`; }
        // チェック状態
        const isChecked = selectedSkus.has(r.amazon_sku);
        const urgTag = r.urgency_score >= 80 ? 'red' : r.urgency_score >= 40 ? 'yellow' : 'white';
        return `<tr class="${urgCls}" ${manualCls}>
          <td style="text-align:center;"><input type="checkbox" class="rec-check" data-sku="${r.amazon_sku}" data-qty="${shipQtyMap[r.amazon_sku] ?? (r.adjusted_qty || 0)}" data-urg="${urgTag}" ${isChecked ? 'checked' : ''} onchange="onCheckChange(this)"></td>
          <td style="text-align:center;font-size:11px;color:#666;">${rowNum}</td>
          <td>${r._manual ? '手動' : r.urgency_score}</td>
          <td><span class="sku-link" onclick="showCalcDetail('${r.amazon_sku}')">${r.amazon_sku}</span></td>
          <td class="product-name" title="${r.product_name || ''}">${r.asin ? `<a href="https://www.amazon.co.jp/dp/${r.asin}" target="_blank" style="color:inherit;text-decoration:none;" title="Amazonで開く">${r.product_name || ''}</a>` : (r.product_name || '')}</td>
          ${renderComponentCell(r)}
          <td>${r.fba_available}</td>
          <td>${r.effective_fba_stock}</td>
          <td style="${dosColor}">${dosVal}${belowReorder ? ' ⚠' : ''}</td>
          <td>${reorderVal}</td>
          <td>${r.raw_needed || 0}</td>
          <td>${r.target_days}</td>
          <td>${r.units_sold_7d}</td>
          <td>${r.units_sold_30d}</td>
          <td>${r.non_fba_sales_7d || 0}</td>
          <td style="${(r.non_fba_sales_30d || 0) > 0 ? 'font-weight:bold;color:#7c3aed' : ''}">${r.non_fba_sales_30d || 0}</td>
          <td>${r.warehouse_raw || r.warehouse_available}</td>
          <td style="color:#2563eb;font-weight:bold">${r.warehouse_available}</td>
          <td style="${(r.non_fba_reserve || 0) > 0 ? 'font-weight:bold;color:#dc2626' : 'color:#999'}">${r.non_fba_reserve || 0}</td>
          <td class="rec-qty" style="${r.recommended_qty !== r.adjusted_qty ? 'color:#999;font-size:12px;text-decoration:line-through' : ''}">${r.recommended_qty || '-'}</td>
          <td class="rec-qty" style="font-size:11px;color:#666;">${r.adjusted_qty || '-'}${r.location_adjusted ? ' 📍' : ''}</td>
          <td style="padding:2px 4px;"><input type="number" class="ship-qty-input" data-sku="${r.amazon_sku}" value="${shipQtyMap[r.amazon_sku] ?? (r.adjusted_qty || 0)}" min="0" onchange="onShipQtyChange(this)" onfocus="this.select()" style="width:60px;padding:3px 4px;border:1px solid #d1d5db;border-radius:4px;font-size:13px;text-align:right;${(shipQtyMap[r.amazon_sku] !== undefined && shipQtyMap[r.amazon_sku] !== (r.adjusted_qty || 0)) ? 'background:#fef3c7;border-color:#d97706;font-weight:bold;' : ''}"></td>
          <td>${alertsHtml}</td>
        </tr>`;
      }).join('');
    }

    document.addEventListener('click', e => {
      const th = e.target.closest('th.sortable-rec');
      if (th) {
        const key = th.dataset.key;
        if (recSortKey === key) recSortDir = recSortDir === 'asc' ? 'desc' : 'asc';
        else { recSortKey = key; recSortDir = 'desc'; }
        document.querySelectorAll('th.sortable-rec').forEach(t => t.classList.remove('asc', 'desc'));
        th.classList.add(recSortDir);
        filterRecList();
        return;
      }
      // 新規商品テーブルのソート
      const th5 = e.target.closest('th.sortable-new');
      if (th5) {
        const key = th5.dataset.key;
        if (newSortKey === key) newSortDir = newSortDir === 'asc' ? 'desc' : 'asc';
        else { newSortKey = key; newSortDir = 'desc'; }
        document.querySelectorAll('th.sortable-new').forEach(t => t.classList.remove('asc', 'desc'));
        th5.classList.add(newSortDir);
        filterNewList();
        return;
      }
      // FBA欠品テーブルのソート
      const th4 = e.target.closest('th.sortable-stockout');
      if (th4) {
        const key = th4.dataset.key;
        if (stockoutSortKey === key) stockoutSortDir = stockoutSortDir === 'asc' ? 'desc' : 'asc';
        else { stockoutSortKey = key; stockoutSortDir = 'desc'; }
        document.querySelectorAll('th.sortable-stockout').forEach(t => t.classList.remove('asc', 'desc'));
        th4.classList.add(stockoutSortDir);
        filterStockoutList();
        return;
      }
      // 発注推奨テーブルのソート
      const th3 = e.target.closest('th.sortable-order');
      if (th3) {
        const key = th3.dataset.key;
        if (orderSortKey === key) orderSortDir = orderSortDir === 'asc' ? 'desc' : 'asc';
        else { orderSortKey = key; orderSortDir = 'desc'; }
        document.querySelectorAll('th.sortable-order').forEach(t => t.classList.remove('asc', 'desc'));
        th3.classList.add(orderSortDir);
        filterOrderList();
        return;
      }
      // スナップショットテーブルのソート
      const th2 = e.target.closest('th.sortable');
      if (!th2) return;
      const key = th2.dataset.key;
      if (sortKey === key) sortDir = sortDir === 'asc' ? 'desc' : 'asc';
      else { sortKey = key; sortDir = 'asc'; }
      document.querySelectorAll('th.sortable').forEach(t => t.classList.remove('asc', 'desc'));
      th2.classList.add(sortDir);
      sortAndRender();
    });

    function showCalcDetail(sku) {
      const item = recData.find(r => r.amazon_sku === sku);
      if (!item) return;
      const steps = item.calc_steps || ['デバッグ情報なし'];
      const html = `
        <div class="debug-overlay" onclick="this.parentElement.remove()"></div>
        <div class="debug-modal">
          <span class="debug-close" onclick="this.parentElement.parentElement.remove()">&times;</span>
          <h3 style="margin:0 0 8px">${sku}</h3>
          <p style="color:#666;margin:0 0 12px;font-size:13px">${item.product_name || ''}</p>
          <div style="margin-bottom:12px;">
            <strong>NE商品コード:</strong> ${item.ne_code || '-'} |
            <strong>ASIN:</strong> ${item.asin || '-'} |
            <strong>セット:</strong> ${item.is_set ? 'はい' : 'いいえ'}
          </div>
          <h4 style="margin:12px 0 8px;">計算過程</h4>
          ${steps.map(s => `<div class="debug-step">${s}</div>`).join('')}
        </div>`;
      const div = document.createElement('div');
      div.innerHTML = html;
      document.body.appendChild(div);
    }

    async function syncSkuMappings() {
      const btn = document.getElementById('btnSyncSku');
      btn.disabled = true;
      btn.innerHTML = '<span class="spinner"></span>同期中...';
      log('SKUマッピング同期開始...');

      try {
        const res = await fetch(`${BASE}/api/sync-sku-mappings`, { method: 'POST' });
        const d = await res.json();
        if (d.error) { log('エラー: ' + d.error); return; }
        log(`完了! ${d.total}件同期 (単品: ${d.singles}件, セット: ${d.sets}件)`);
        loadStatus();
        completeStep(3);
      } catch (e) { log('エラー: ' + e.message); }
      finally {
        btn.disabled = false;
        btn.textContent = 'SKUマッピング同期';
      }
    }

    // ===== 設定パネル =====
    const SETTINGS_SCHEMA = [
