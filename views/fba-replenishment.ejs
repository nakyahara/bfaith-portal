              <tr style="background:#f3f4f6;"><th style="padding:6px;border:1px solid #e5e7eb;">問題</th><th style="padding:6px;border:1px solid #e5e7eb;">対処</th></tr>
              <tr><td style="padding:6px;border:1px solid #e5e7eb;">FNSKU除外が「一致なし」になる</td><td style="padding:6px;border:1px solid #e5e7eb;">SP-APIレポート全取得を実行してFNSKUをDBに保存 → 推奨リスト再生成。デプロイ後はFNSKUがリセットされるため再取得が必要。</td></tr>
              <tr><td style="padding:6px;border:1px solid #e5e7eb;">INVENTORYレポートがFATAL</td><td style="padding:6px;border:1px solid #e5e7eb;">リトライで解消。UNSUPPRESSED→ALL_INVENTORYのフォールバック実装済み。</td></tr>
              <tr><td style="padding:6px;border:1px solid #e5e7eb;">「レポート取得中です」エラー</td><td style="padding:6px;border:1px solid #e5e7eb;">前回のフェッチ未完了。1〜2分待ってリトライ。</td></tr>
              <tr><td style="padding:6px;border:1px solid #e5e7eb;">昨日送った商品がまた推奨に上がる</td><td style="padding:6px;border:1px solid #e5e7eb;">セラセンでプラン作成済みなら、翌日のSP-APIレポートで「準備中」に反映される。Step1を毎日実行すれば問題なし。反映にタイムラグあり（数時間〜翌日）。</td></tr>
              <tr><td style="padding:6px;border:1px solid #e5e7eb;">仮確定データが消えた</td><td style="padding:6px;border:1px solid #e5e7eb;">「仮確定に移動」は差分マージ方式（既存データを保持して追加・更新）。全件クリアしたい場合は仮確定タブの「クリア」ボタンを使用。</td></tr>
              <tr><td style="padding:6px;border:1px solid #e5e7eb;">NE CSVの商品コードが空</td><td style="padding:6px;border:1px solid #e5e7eb;">SKUマッピングにNE商品コードがない。Google Sheetsの変換テーブルにD列（NE商品コード）を追加。</td></tr>
              <tr><td style="padding:6px;border:1px solid #e5e7eb;">セラセンで数量変更したい</td><td style="padding:6px;border:1px solid #e5e7eb;">セラセンで直接変更、またはプラン削除→ツールで数量変更→再度Excel出力。</td></tr>
              <tr><td style="padding:6px;border:1px solid #e5e7eb;">デプロイ後にデータが消えた</td><td style="padding:6px;border:1px solid #e5e7eb;">RenderデプロイでSQLiteがリセットされる。Step1〜3を再実行すれば復元。仮確定データ・出力履歴も消えるので注意。</td></tr>
            </table>
          </div>

          <div class="settings-group">
            <h4>用語集</h4>
            <table style="width:100%;font-size:12px;border-collapse:collapse;">
              <tr style="background:#f3f4f6;"><th style="padding:6px;border:1px solid #e5e7eb;width:30%;">用語</th><th style="padding:6px;border:1px solid #e5e7eb;">意味</th></tr>
              <tr><td style="padding:6px;border:1px solid #e5e7eb;">FNSKU</td><td style="padding:6px;border:1px solid #e5e7eb;">AmazonがFBA商品に付与するバーコード。SKUと1対1。危険物判定で梱包グループが分かれる際の識別に使用。</td></tr>
              <tr><td style="padding:6px;border:1px solid #e5e7eb;">準備中(inbound_working)</td><td style="padding:6px;border:1px solid #e5e7eb;">セラセンで納品プランを作成済みだがまだ発送していない状態の数量。実質FBA在庫に加算される。3日超で除外。</td></tr>
              <tr><td style="padding:6px;border:1px solid #e5e7eb;">発注点</td><td style="padding:6px;border:1px solid #e5e7eb;">FBA在庫がこの日数分を下回ったら推奨に上がる閾値。回転率で変動。</td></tr>
              <tr><td style="padding:6px;border:1px solid #e5e7eb;">目標日数</td><td style="padding:6px;border:1px solid #e5e7eb;">推奨に上がった時に何日分送るか。回転率×サイズで決定。</td></tr>
              <tr><td style="padding:6px;border:1px solid #e5e7eb;">按分</td><td style="padding:6px;border:1px solid #e5e7eb;">倉庫在庫をFBAと他CH（楽天等）の販売比率で配分すること。FBAに送りすぎて他CHの販売機会を逃さないため。</td></tr>
              <tr><td style="padding:6px;border:1px solid #e5e7eb;">Yロケ</td><td style="padding:6px;border:1px solid #e5e7eb;">ロジザードの出庫禁止ロケーション。施設（いろは）に預けている在庫。計算対象外。</td></tr>
              <tr><td style="padding:6px;border:1px solid #e5e7eb;">set_components</td><td style="padding:6px;border:1px solid #e5e7eb;">1つのAmazon SKUが複数のNE商品コードで構成されている場合の展開情報。NE CSV出力時に使用。</td></tr>
            </table>
          </div>
          </div><!-- /mtFaqContent -->

          </div><!-- /scroll container -->
        </div>`;

      const div = document.createElement('div');
      div.id = 'manualContainer';
      div.innerHTML = html;
      document.body.appendChild(div);
    }

    function switchManualTab(tab) {
      ['workflow','calc','guide','faq'].forEach(t => {
        const btn = document.getElementById('mt' + t.charAt(0).toUpperCase() + t.slice(1));
        const content = document.getElementById('mt' + t.charAt(0).toUpperCase() + t.slice(1) + 'Content');
        if (btn) { btn.style.background = t === tab ? '#2563eb' : '#f3f4f6'; btn.style.color = t === tab ? '#fff' : '#333'; }
        if (content) content.style.display = t === tab ? '' : 'none';
      });
    }

    function closeManual() {
      const c = document.getElementById('manualContainer');
      if (c) c.remove();
    }

    function closeSettings() {
      const c = document.getElementById('settingsContainer');
      if (c) c.remove();
    }

    async function saveSetting(input) {
      const key = input.dataset.key;
      const value = input.value.trim();
      try {
        await fetch(`${BASE}/api/settings`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ [key]: value })
        });
        const saved = document.getElementById('saved_' + key);
        if (saved) { saved.style.opacity = '1'; setTimeout(() => saved.style.opacity = '0', 2000); }
      } catch(e) { alert('設定保存エラー: ' + e.message); }
    }

    // ===== タブ切り替え =====
    function switchTab(tab) {
      document.getElementById('tabShip').classList.toggle('active', tab === 'ship');
      document.getElementById('tabStockout').classList.toggle('active', tab === 'stockout');
      document.getElementById('tabNew').classList.toggle('active', tab === 'new');
      document.getElementById('tabOrder').classList.toggle('active', tab === 'order');
      document.getElementById('tabProvisional').classList.toggle('active', tab === 'provisional');
      // tabPicking廃止済み
      // document.getElementById('tabPicking').classList.toggle('active', tab === 'picking');
      document.getElementById('tabShipContent').style.display = tab === 'ship' ? '' : 'none';
      document.getElementById('tabStockoutContent').style.display = tab === 'stockout' ? '' : 'none';
      document.getElementById('tabNewContent').style.display = tab === 'new' ? '' : 'none';
      document.getElementById('tabOrderContent').style.display = tab === 'order' ? '' : 'none';
      document.getElementById('tabProvisionalContent').style.display = tab === 'provisional' ? '' : 'none';
      // document.getElementById('tabPickingContent').style.display = tab === 'picking' ? '' : 'none';
    }

    // ===== 発注推奨リスト =====
    let orderData = [];
    let orderSortKey = 'urgency_score';
    let orderSortDir = 'desc';

    function updateOrderList() {
      // 実質FBA在庫0 かつ 倉庫在庫も0（送りたいけど送れない）
      orderData = recData.filter(r =>
        r.effective_fba_stock === 0 && (r.warehouse_raw || 0) === 0
      );
      // タブのカウント更新
      const countEl = document.getElementById('orderTabCount');
      if (orderData.length > 0) {
        countEl.textContent = orderData.length;
        countEl.style.display = '';
      } else {
        countEl.style.display = 'none';
      }
      // サマリー更新
      const withSales = orderData.filter(r => (r.units_sold_30d || 0) > 0 || (r.non_fba_sales_30d || 0) > 0);
      document.getElementById('orderSkuCount').textContent = orderData.length + ' SKU';
      document.getElementById('orderNeedCount').textContent = withSales.length + ' SKU';
      document.getElementById('orderNoSalesCount').textContent = (orderData.length - withSales.length) + ' SKU';
      filterOrderList();
    }

    function filterOrderList() {
      const mode = document.querySelector('input[name="orderFilter"]:checked')?.value || 'with_sales';
      const searchQuery = (document.getElementById('orderSearch')?.value || '').trim().toLowerCase();
      let filtered = orderData;
      if (mode === 'with_sales') {
        filtered = filtered.filter(r => (r.units_sold_30d || 0) > 0 || (r.non_fba_sales_30d || 0) > 0);
      }
      if (searchQuery) {
        filtered = filtered.filter(r =>
          (r.product_name || '').toLowerCase().includes(searchQuery) ||
          (r.amazon_sku || '').toLowerCase().includes(searchQuery) ||
          (r.ne_code || '').toLowerCase().includes(searchQuery)
        );
      }
      renderOrderList(filtered);
      document.getElementById('orderFilterCount').textContent = `表示: ${filtered.length} 件`;
      syncSnapshotSearch(searchQuery);
    }

    function renderOrderList(data) {
      const tbody = document.getElementById('orderBody');
      if (!data.length) { tbody.innerHTML = '<tr><td colspan="22">該当なし</td></tr>'; return; }

      // ソート
      data.sort((a, b) => {
        const th = document.querySelector(`th.sortable-order[data-key="${orderSortKey}"]`);
        const isNum = th?.dataset.type === 'num';
        let va = a[orderSortKey], vb = b[orderSortKey];
        if (isNum) { va = parseFloat(va) || 0; vb = parseFloat(vb) || 0; }
        else { va = String(va || ''); vb = String(vb || ''); }
        if (va < vb) return orderSortDir === 'asc' ? -1 : 1;
        if (va > vb) return orderSortDir === 'asc' ? 1 : -1;
        return 0;
      });

      let num = 0;
      tbody.innerHTML = data.map(r => {
        num++;
        const hasSales = (r.units_sold_30d || 0) > 0 || (r.non_fba_sales_30d || 0) > 0;
        const rowBg = hasSales ? 'background:#fee2e2;' : '';
        const dosVal = r.days_of_supply;
        const dosColor = typeof dosVal === 'number' && dosVal < 7 ? 'color:#dc2626;font-weight:bold' : typeof dosVal === 'number' && dosVal < 14 ? 'color:#d97706' : '';
        let alertsHtml = (r.alerts || []).map(a =>
          `<span class="alert-badge alert-${a.level}" title="${a.message}">${a.level >= 2 ? '⚠' : 'ℹ'} ${a.message.slice(0,15)}</span>`
        ).join('');
        return `<tr style="${rowBg}">
          <td style="text-align:center;color:#666;">${num}</td>
          <td>${r.urgency_score}</td>
          <td><span class="sku-link" onclick="showCalcDetail('${r.amazon_sku}')">${r.amazon_sku}</span></td>
          <td class="product-name" title="${esc(r.product_name)}">${r.asin ? `<a href="https://www.amazon.co.jp/dp/${r.asin}" target="_blank" style="color:inherit;text-decoration:none;">${esc(r.product_name)}</a>` : esc(r.product_name)}</td>
          ${renderComponentCell(r)}
          <td>${r.fba_available}</td>
          <td style="${r.fba_inbound_working > 0 ? (r.fba_inbound_working_source === 'API' ? 'color:#2563eb;font-weight:bold' : 'color:#16a34a') : 'color:#ccc'}">${r.fba_inbound_working || 0}${r.fba_inbound_working_source === 'API' ? '<span style="font-size:9px;color:#2563eb;"> ⚡</span>' : ''}</td>
          <td>${r.effective_fba_stock}</td>
          <td style="${dosColor}">${dosVal}</td>
          <td>${r.reorder_point}</td>
          <td>${r.raw_needed || 0}</td>
          <td>${r.target_days}</td>
          <td>${r.units_sold_7d}</td>
          <td>${r.units_sold_30d}</td>
          <td>${r.non_fba_sales_7d || 0}</td>
          <td style="${(r.non_fba_sales_30d || 0) > 0 ? 'font-weight:bold;color:#7c3aed' : ''}">${r.non_fba_sales_30d || 0}</td>
          <td>${r.warehouse_raw || 0}</td>
          <td style="color:#2563eb;font-weight:bold">${r.warehouse_available}</td>
          <td style="${(r.non_fba_reserve || 0) > 0 ? 'font-weight:bold;color:#dc2626' : 'color:#999'}">${r.non_fba_reserve || 0}</td>
          <td class="rec-qty">${r.recommended_qty || '-'}</td>
          <td class="rec-qty">${r.adjusted_qty || '-'}</td>
          <td>${alertsHtml}</td>
        </tr>`;
      }).join('');
    }

    // ===== FBA欠品リスト =====
    let stockoutData = [];
    let stockoutSortKey = 'stockout_status';
    let stockoutSortDir = 'asc';
    const stockoutCheckedSkus = new Set();
    let stockoutHiddenSet = new Set(); // 非表示SKUセット

    // 非表示リストをDBから読み込み
    async function loadStockoutHidden() {
      try {
        const res = await fetch(`${BASE}/api/stockout-hidden`);
        const list = await res.json();
        stockoutHiddenSet = new Set(list.map(r => r.amazon_sku));
        document.getElementById('stockoutHiddenCount').textContent = `(${stockoutHiddenSet.size}件)`;
      } catch(e) { /* ignore */ }
    }

    async function updateStockoutList() {
      // 非表示リストを先に読み込む
      await loadStockoutHidden();

      // FBA販売可能在庫 = 0 の全商品（SKUマッピングありのみ = recDataに含まれるもの）
      stockoutData = recData.filter(r => r.fba_available === 0).map(r => {
        // ステータス判定
        let stockout_status, stockout_status_num;
        if (r.recommended_qty > 0 || manualItems.find(m => m.amazon_sku === r.amazon_sku)) {
          stockout_status = 'already'; // 納品推奨済み
          stockout_status_num = 2;
        } else if ((r.warehouse_raw || 0) > 0) {
          stockout_status = 'sendable'; // 倉庫在庫あり → 送れる
          stockout_status_num = 1;
        } else {
          stockout_status = 'nostock'; // 在庫なし
          stockout_status_num = 3;
        }
        const is_hidden = stockoutHiddenSet.has(r.amazon_sku);
        return { ...r, stockout_status, stockout_status_num, is_hidden };
      });

      // タブカウント（非表示を除いた数）
      const visibleData = stockoutData.filter(r => !r.is_hidden);
      const countEl = document.getElementById('stockoutTabCount');
      if (visibleData.length > 0) {
        countEl.textContent = visibleData.length;
        countEl.style.display = '';
      } else {
        countEl.style.display = 'none';
      }

      // サマリー（非表示を除いた数）
      const sendableCount = visibleData.filter(r => r.stockout_status === 'sendable').length;
      document.getElementById('stockoutTotalCount').textContent = visibleData.length + ' SKU';
      document.getElementById('stockoutSendableCount').textContent = sendableCount + ' SKU';
      document.getElementById('stockoutAlreadyCount').textContent = visibleData.filter(r => r.stockout_status === 'already').length + ' SKU';
      document.getElementById('stockoutNoStockCount').textContent = visibleData.filter(r => r.stockout_status === 'nostock').length + ' SKU';

      filterStockoutList();
    }

    function filterStockoutList() {
      const mode = document.querySelector('input[name="stockoutFilter"]:checked')?.value || 'sendable';
      const stateMode = document.querySelector('input[name="stockoutStateFilter"]:checked')?.value || 'all';
      const minAmazonReco = parseInt(document.getElementById('stockoutMinAmazonReco')?.value || '0') || 0;
      const searchQuery = (document.getElementById('stockoutSearch')?.value || '').trim().toLowerCase();
      const showHidden = document.getElementById('stockoutShowHidden')?.checked || false;

      let filtered = stockoutData;
      // 非表示フィルター（デフォルトは非表示を除外）
      if (!showHidden) {
        filtered = filtered.filter(r => !r.is_hidden);
      }
      if (mode === 'sendable') {
        filtered = filtered.filter(r => r.stockout_status === 'sendable');
      }
      // 状態分類フィルタ (stock_state: recent_oos / revivable_long_oos / dead_candidate)
      if (stateMode === 'recent') {
        filtered = filtered.filter(r => r.stock_state === 'recent_oos');
      } else if (stateMode === 'long') {
        filtered = filtered.filter(r => r.stock_state === 'revivable_long_oos');
      } else if (stateMode === 'dead') {
        filtered = filtered.filter(r => r.stock_state === 'dead_candidate');
      }
      // Amazon推奨数 閾値フィルタ (null と 0 を区別、閾値≥1の時は null を除外)
      if (minAmazonReco > 0) {
        filtered = filtered.filter(r => typeof r.amazon_recommended_qty === 'number' && r.amazon_recommended_qty >= minAmazonReco);
      }
      if (searchQuery) {
        filtered = filtered.filter(r =>
          (r.product_name || '').toLowerCase().includes(searchQuery) ||
          (r.amazon_sku || '').toLowerCase().includes(searchQuery) ||
          (r.ne_code || '').toLowerCase().includes(searchQuery)
        );
      }
      renderStockoutList(filtered);
      document.getElementById('stockoutFilterCount').textContent = `表示: ${filtered.length} 件`;
      syncSnapshotSearch(searchQuery);
    }

    function renderStockoutList(data) {
      const tbody = document.getElementById('stockoutBody');
      if (!data.length) { tbody.innerHTML = '<tr><td colspan="25">該当なし</td></tr>'; return; }

      // ソート
      data.sort((a, b) => {
        const th = document.querySelector(`th.sortable-stockout[data-key="${stockoutSortKey}"]`);
        const isNum = th?.dataset.type === 'num' || stockoutSortKey === 'stockout_status';
        let va, vb;
        if (stockoutSortKey === 'stockout_status') {
          va = a.stockout_status_num; vb = b.stockout_status_num;
        } else if (isNum) {
          va = parseFloat(a[stockoutSortKey]) || 0; vb = parseFloat(b[stockoutSortKey]) || 0;
        } else {
          va = String(a[stockoutSortKey] || ''); vb = String(b[stockoutSortKey] || '');
        }
        if (va < vb) return stockoutSortDir === 'asc' ? -1 : 1;
        if (va > vb) return stockoutSortDir === 'asc' ? 1 : -1;
        return 0;
      });

      let num = 0;
      tbody.innerHTML = data.map(r => {
        num++;
        const isSendable = r.stockout_status === 'sendable';
        const isAlready = r.stockout_status === 'already';
        const isNostock = r.stockout_status === 'nostock';
        const isHidden = r.is_hidden;

        // ステータスバッジ
        let statusHtml;
        if (isHidden) {
          statusHtml = '<span class="stockout-badge" style="background:#e5e7eb;color:#6b7280;">非表示</span>';
        } else if (isAlready) {
          statusHtml = '<span class="stockout-badge stockout-already">納品推奨済み ✓</span>';
        } else if (isSendable) {
          statusHtml = '<span class="stockout-badge stockout-sendable">送り漏れ</span>';
        } else {
          statusHtml = '<span class="stockout-badge stockout-nostock">在庫なし</span>';
        }

        // 非表示の場合は復元ボタン
        if (isHidden) {
          statusHtml += ` <span style="font-size:11px;color:#2563eb;cursor:pointer;text-decoration:underline;" onclick="unhideStockoutSku('${r.amazon_sku}')">復元</span>`;
        }

        // チェックボックス: 送り漏れ or 非表示(復元チェック用)で有効
        const checkEnabled = isSendable || isHidden || isNostock;
        const isChecked = stockoutCheckedSkus.has(r.amazon_sku);
        const checkHtml = !checkEnabled
          ? `<input type="checkbox" disabled style="opacity:0.3;">`
          : `<input type="checkbox" class="stockout-check" data-sku="${r.amazon_sku}" ${isChecked ? 'checked' : ''} onchange="onStockoutCheckChange(this)">`;

        // 行の背景色
        const rowBg = isHidden ? 'background:#f3f4f6;opacity:0.7;' : isSendable ? 'background:#fff5f5;' : isAlready ? 'background:#fffbeb;' : '';

        // アラート
        let alertsHtml = (r.alerts || []).map(a =>
          `<span class="alert-badge alert-${a.level}" title="${a.message}">${a.level >= 2 ? '⚠' : 'ℹ'} ${a.message.slice(0,15)}</span>`
        ).join('');

        // 輸送中/準備中があれば補足
        const inTransit = (r.fba_inbound_shipped || 0) + (r.fba_inbound_working || 0);
        if (inTransit > 0 && !isAlready) {
          alertsHtml += `<span class="alert-badge alert-1">輸送/準備中 ${inTransit}個</span>`;
        }

        const dosVal = r.days_of_supply;
        const dosColor = typeof dosVal === 'number' && dosVal < 7 ? 'color:#dc2626;font-weight:bold' : typeof dosVal === 'number' && dosVal < 14 ? 'color:#d97706' : '';
        const reorderVal = r.reorder_point;
        const belowReorder = typeof r.effective_fba_stock === 'number' && typeof reorderVal === 'number' && r.effective_fba_stock < reorderVal;

        // stock_state バッジ
        const stateLabels = {
          'normal': { label: '通常', bg: '#d1fae5', color: '#065f46' },
          'recent_oos': { label: '直近欠品', bg: '#fee2e2', color: '#991b1b' },
          'revivable_long_oos': { label: '長期(復活余地)', bg: '#fef3c7', color: '#92400e' },
          'dead_candidate': { label: '廃番候補', bg: '#e5e7eb', color: '#4b5563' },
        };
        const stateInfo = stateLabels[r.stock_state] || { label: r.stock_state || '-', bg: '#e5e7eb', color: '#4b5563' };
        const stateBadgeHtml = `<span style="display:inline-block;font-size:10px;padding:1px 6px;border-radius:3px;background:${stateInfo.bg};color:${stateInfo.color};font-weight:bold;">${stateInfo.label}</span>`;

        // Amazon推奨数 (null は "-")
        const amzRecoHtml = typeof r.amazon_recommended_qty === 'number'
          ? `<span style="${r.amazon_reco_capped ? 'color:#dc2626;font-weight:bold' : 'color:#2563eb'}">${r.amazon_recommended_qty}</span>`
          : '<span style="color:#ccc">-</span>';

        return `<tr style="${rowBg}">
          <td style="text-align:center;">${checkHtml}</td>
          <td style="text-align:center;color:#666;font-size:11px;">${num}</td>
          <td>${statusHtml}</td>
          <td>${stateBadgeHtml}${r.is_expiry_managed ? '<span style="font-size:10px;margin-left:3px;color:#7c3aed" title="期限管理商品">⏳</span>' : ''}</td>
          <td><span class="sku-link" onclick="showCalcDetail('${r.amazon_sku}')">${r.amazon_sku}</span></td>
          <td class="product-name" title="${esc(r.product_name)}">${r.asin ? `<a href="https://www.amazon.co.jp/dp/${r.asin}" target="_blank" style="color:inherit;text-decoration:none;" title="Amazonで開く">${esc(r.product_name)}</a>` : esc(r.product_name)}</td>
          ${renderComponentCell(r)}
          <td>${r.fba_available}</td>
          <td style="${r.fba_inbound_working > 0 ? (r.fba_inbound_working_source === 'API' ? 'color:#2563eb;font-weight:bold' : 'color:#16a34a') : 'color:#ccc'}">${r.fba_inbound_working || 0}${r.fba_inbound_working_source === 'API' ? '<span style="font-size:9px;color:#2563eb;"> ⚡</span>' : ''}</td>
          <td>${r.effective_fba_stock}</td>
          <td style="${dosColor}">${dosVal}${belowReorder ? ' ⚠' : ''}</td>
          <td>${reorderVal}</td>
          <td>${r.raw_needed || 0}</td>
          <td>${amzRecoHtml}</td>
          <td>${r.target_days}</td>
          <td>${r.units_sold_7d}</td>
          <td>${r.units_sold_30d}</td>
          <td>${r.non_fba_sales_7d || 0}</td>
          <td style="${(r.non_fba_sales_30d || 0) > 0 ? 'font-weight:bold;color:#7c3aed' : ''}">${r.non_fba_sales_30d || 0}</td>
          <td>${r.warehouse_raw || 0}</td>
          <td style="color:#2563eb;font-weight:bold">${r.warehouse_available}</td>
          <td style="${(r.non_fba_reserve || 0) > 0 ? 'font-weight:bold;color:#dc2626' : 'color:#999'}">${r.non_fba_reserve || 0}</td>
          <td class="rec-qty" style="${r.recommended_qty !== r.adjusted_qty ? 'color:#999;font-size:12px;text-decoration:line-through' : ''}">${r.recommended_qty || '-'}</td>
          <td class="rec-qty" style="font-size:11px;color:#666;">${r.adjusted_qty || '-'}${r.location_adjusted ? ' 📍' : ''}</td>
          <td>${alertsHtml}</td>
        </tr>`;
      }).join('');
    }

    function onStockoutCheckChange(cb) {
      if (cb.checked) {
        stockoutCheckedSkus.add(cb.dataset.sku);
      } else {
        stockoutCheckedSkus.delete(cb.dataset.sku);
      }
    }

    // チェック済みを非表示にする
    async function hideStockoutChecked() {
      const msgEl = document.getElementById('stockoutActionMsg');
      if (stockoutCheckedSkus.size === 0) {
        msgEl.textContent = 'チェックされた商品がありません';
        msgEl.style.color = '#d97706';
        return;
      }
      try {
        const res = await fetch(`${BASE}/api/stockout-hidden`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ skus: [...stockoutCheckedSkus] }),
        });
        const d = await res.json();
        msgEl.textContent = `${d.count}件を非表示にしました`;
        msgEl.style.color = '#16a34a';
        stockoutCheckedSkus.clear();
        await updateStockoutList();
      } catch(e) {
        msgEl.textContent = 'エラー: ' + e.message;
        msgEl.style.color = '#dc2626';
      }
    }

    // 個別SKUの非表示を復元
    async function unhideStockoutSku(sku) {
      try {
        await fetch(`${BASE}/api/stockout-hidden/${encodeURIComponent(sku)}`, { method: 'DELETE' });
        stockoutHiddenSet.delete(sku);
        // データを再計算して再描画
        stockoutData = stockoutData.map(r =>
          r.amazon_sku === sku ? { ...r, is_hidden: false } : r
        );
        document.getElementById('stockoutHiddenCount').textContent = `(${stockoutHiddenSet.size}件)`;
        filterStockoutList();
      } catch(e) { /* ignore */ }
    }

    function addStockoutToShip() {
      const msgEl = document.getElementById('stockoutActionMsg');
      if (stockoutCheckedSkus.size === 0) {
        msgEl.textContent = 'チェックされた商品がありません';
        msgEl.style.color = '#d97706';
        return;
      }

      let addedCount = 0;
      let alreadyCount = 0;
      for (const sku of stockoutCheckedSkus) {
        // 既に納品推奨にあるか確認
        const existing = recData.find(r => r.amazon_sku === sku);
        const existsInManual = manualItems.find(m => m.amazon_sku === sku);

        if (existing && existing.recommended_qty > 0) {
          alreadyCount++;
          continue;
        }
        if (existsInManual) {
          alreadyCount++;
          continue;
        }

        if (existing) {
          // recDataに存在するが推奨数0 → 推奨数0のまま手動追加扱いにする
          existing.recommended_qty = 0;
          existing.adjusted_qty = 0;
          existing._manual = true;
          existing._fromStockout = true;
          addedCount++;
        } else {
          // recDataにない場合 — stockoutDataから商品情報を取得
          const soItem = stockoutData.find(s => s.amazon_sku === sku);
          const snap = snapshotData.find(s => s.amazon_sku === sku);
          const item = {
            amazon_sku: sku,
            asin: soItem?.asin || snap?.asin || '',
            product_name: soItem?.product_name || snap?.product_name || '(FBA欠品から追加)',
            ne_code: soItem?.ne_code || '',
            fnsku: soItem?.fnsku || '',
            fba_available: soItem?.fba_available ?? 0,
            fba_inbound_working: soItem?.fba_inbound_working ?? 0,
            fba_inbound_working_source: soItem?.fba_inbound_working_source || '',
            effective_fba_stock: soItem?.effective_fba_stock ?? 0,
            days_of_supply: soItem?.days_of_supply ?? 0,
            reorder_point: soItem?.reorder_point ?? '-',
            raw_needed: soItem?.raw_needed ?? '-',
            target_days: soItem?.target_days ?? '-',
            units_sold_7d: soItem?.units_sold_7d ?? 0,
            units_sold_30d: soItem?.units_sold_30d ?? 0,
            non_fba_sales_7d: soItem?.non_fba_sales_7d ?? 0,
            non_fba_sales_30d: soItem?.non_fba_sales_30d ?? 0,
            warehouse_raw: soItem?.warehouse_raw ?? 0,
            warehouse_available: soItem?.warehouse_available ?? 0,
            recommended_qty: 0,
            adjusted_qty: 0,
            urgency_score: soItem?.urgency_score ?? 0,
            alerts: soItem?.alerts || [],
            set_components: soItem?.set_components || null,
            _manual: true,
            _fromStockout: true,
          };
          manualItems.push(item);
          addedCount++;
        }
      }

      // チェックをクリア
      stockoutCheckedSkus.clear();

      // メッセージ
      let msg = '';
      if (addedCount > 0) msg += `${addedCount}件を納品推奨に追加しました（数量0 → 手動入力してください）`;
      if (alreadyCount > 0) msg += `${alreadyCount > 0 && addedCount > 0 ? '、' : ''}${alreadyCount}件は既に納品推奨済みです`;
      msgEl.textContent = msg;
      msgEl.style.color = addedCount > 0 ? '#16a34a' : '#d97706';

      // リスト更新
      updateRecSummary();
      filterRecList();
      updateStockoutList(); // ステータス再計算

      // 追加があれば納品推奨タブに切り替え
      if (addedCount > 0) {
        document.getElementById('recSection').style.display = '';
        setTimeout(() => switchTab('ship'), 500);
      }
    }

    // ===== 新規商品リスト =====
    let newProductData = [];
    let newSortKey = 'warehouse_qty';
    let newSortDir = 'desc';
    let newHiddenSet = new Set();
    const newCheckedSkus = new Set();

    async function loadNewProductHidden() {
      try {
        const res = await fetch(`${BASE}/api/new-product-hidden`);
        const list = await res.json();
        newHiddenSet = new Set(list.map(r => r.amazon_sku));
        document.getElementById('newHiddenCount').textContent = `(${newHiddenSet.size}件)`;
      } catch(e) { /* ignore */ }
    }

    async function updateNewProductList() {
      if (Object.keys(skuMappingMap).length === 0) await loadSkuMappingMap();
      await loadNewProductHidden();

      // 全期間のスナップショットSKUを取得（過去にFBAに送ったことがあるSKUを除外）
      let snapshotSkuSet;
      try {
        const res = await fetch(`${BASE}/api/all-snapshot-skus`);
        const skus = await res.json();
        snapshotSkuSet = new Set(skus);
      } catch(e) {
        // フォールバック: recDataから取得
        snapshotSkuSet = new Set(recData.map(r => r.amazon_sku));
      }

      newProductData = [];
      for (const [sku, mapping] of Object.entries(skuMappingMap)) {
        if (snapshotSkuSet.has(sku)) continue;

        let warehouseQty = 0;
        let yQty = 0;
        const comps = mapping.set_components
          ? (typeof mapping.set_components === 'string' ? JSON.parse(mapping.set_components) : mapping.set_components)
          : null;

        if (comps && comps.length > 0) {
          let minSets = Infinity;
          for (const comp of comps) {
            const whRows = warehouseSummaryMap[comp.ne_code];
            const available = whRows?.warehouse_available || 0;
            minSets = Math.min(minSets, Math.floor(available / (comp.qty || 1)));
            yQty += whRows?.y_location_qty || 0;
          }
          warehouseQty = minSets === Infinity ? 0 : minSets;
        } else {
          const whRows = warehouseSummaryMap[mapping.logizard_code || mapping.ne_code];
          warehouseQty = whRows?.warehouse_available || 0;
          yQty = whRows?.y_location_qty || 0;
        }

        newProductData.push({
          amazon_sku: sku,
          asin: mapping.asin || '',
          product_name: mapping.product_name || '',
          ne_code: mapping.ne_code || '',
          set_components: comps,
          is_set: mapping.is_set ? true : false,
          warehouse_qty: warehouseQty,
          warehouse_available: warehouseQty,
          y_qty: yQty,
          is_hidden: newHiddenSet.has(sku),
          // SP-API fields not available for new products
          fba_available: '-',
          effective_fba_stock: '-',
          days_of_supply: '-',
          reorder_point: '-',
          raw_needed: '-',
          target_days: '-',
          units_sold_7d: '-',
          units_sold_30d: '-',
          non_fba_sales_7d: mapping.non_fba_sales_7d || 0,
          non_fba_sales_30d: mapping.non_fba_sales_30d || 0,
          non_fba_reserve: '-',
          recommended_qty: '-',
          adjusted_qty: '-',
          alerts: [],
        });
      }

      // タブカウント（非表示除外 + 倉庫在庫ありのみ）
      const visibleData = newProductData.filter(r => !r.is_hidden);
      const readyCount = visibleData.filter(r => r.warehouse_qty > 0).length;
      const countEl = document.getElementById('newTabCount');
      if (readyCount > 0) {
        countEl.textContent = readyCount;
        countEl.style.display = '';
      } else {
        countEl.style.display = 'none';
      }

      // サマリー（非表示除外）
      document.getElementById('newTotalCount').textContent = visibleData.length + ' SKU';
      document.getElementById('newReadyCount').textContent = readyCount + ' SKU';
      document.getElementById('newNoStockCount').textContent = (visibleData.length - readyCount) + ' SKU';

      filterNewList();
    }

    function filterNewList() {
      const mode = document.querySelector('input[name="newFilter"]:checked')?.value || 'ready';
      const searchQuery = (document.getElementById('newSearch')?.value || '').trim().toLowerCase();
      const showHidden = document.getElementById('newShowHidden')?.checked || false;

      let filtered = newProductData;
      if (!showHidden) {
        filtered = filtered.filter(r => !r.is_hidden);
      }
      if (mode === 'ready') {
        filtered = filtered.filter(r => r.warehouse_qty > 0);
      }
      if (searchQuery) {
        filtered = filtered.filter(r =>
          (r.product_name || '').toLowerCase().includes(searchQuery) ||
          (r.amazon_sku || '').toLowerCase().includes(searchQuery) ||
          (r.ne_code || '').toLowerCase().includes(searchQuery)
        );
      }
      renderNewList(filtered);
      document.getElementById('newFilterCount').textContent = `表示: ${filtered.length} 件`;
      syncSnapshotSearch(searchQuery);
    }

    function renderNewList(data) {
      const tbody = document.getElementById('newBody');
      if (!data.length) { tbody.innerHTML = '<tr><td colspan="23">該当なし</td></tr>'; return; }

      data.sort((a, b) => {
        const th = document.querySelector(`th.sortable-new[data-key="${newSortKey}"]`);
        const isNum = th?.dataset.type === 'num';
        let va = a[newSortKey], vb = b[newSortKey];
        if (isNum) { va = parseFloat(va) || 0; vb = parseFloat(vb) || 0; }
        else { va = String(va || ''); vb = String(vb || ''); }
        if (va < vb) return newSortDir === 'asc' ? -1 : 1;
        if (va > vb) return newSortDir === 'asc' ? 1 : -1;
        return 0;
      });

      let num = 0;
      tbody.innerHTML = data.map(r => {
        num++;
        const hasStock = r.warehouse_qty > 0;
        const isHidden = r.is_hidden;
        const rowBg = isHidden ? 'background:#f3f4f6;opacity:0.7;' : hasStock ? 'background:#f0fdf4;' : '';

        let statusHtml;
        if (isHidden) {
          statusHtml = '<span class="stockout-badge" style="background:#e5e7eb;color:#6b7280;">非表示</span>';
          statusHtml += ` <span style="font-size:11px;color:#2563eb;cursor:pointer;text-decoration:underline;" onclick="unhideNewProduct('${r.amazon_sku}')">復元</span>`;
        } else if (hasStock) {
          statusHtml = '<span class="stockout-badge" style="background:#dcfce7;color:#16a34a;">送れる</span>';
        } else {
          statusHtml = '<span class="stockout-badge stockout-nostock">在庫なし</span>';
        }

        const isChecked = newCheckedSkus.has(r.amazon_sku);
        const checkHtml = `<input type="checkbox" class="new-check" data-sku="${r.amazon_sku}" ${isChecked ? 'checked' : ''} onchange="onNewCheckChange(this)">`;

        // アラート
        let alertsHtml = (r.alerts || []).map(a =>
          `<span class="alert-badge alert-${a.level}" title="${a.message}">${a.level >= 2 ? '⚠' : 'ℹ'} ${a.message.slice(0,15)}</span>`
        ).join('');

        return `<tr style="${rowBg}">
          <td style="text-align:center;">${checkHtml}</td>
          <td style="text-align:center;color:#666;font-size:11px;">${num}</td>
          <td>${statusHtml}</td>
          <td><span class="sku-link" onclick="showCalcDetail('${r.amazon_sku}')">${r.amazon_sku}</span></td>
          <td class="product-name" title="${esc(r.product_name)}">${r.asin ? `<a href="https://www.amazon.co.jp/dp/${r.asin}" target="_blank" style="color:inherit;text-decoration:none;" title="Amazonで開く">${esc(r.product_name)}</a>` : esc(r.product_name)}</td>
          ${renderComponentCell(r)}
          <td>${r.fba_available ?? '-'}</td>
          <td style="${r.fba_inbound_working > 0 ? (r.fba_inbound_working_source === 'API' ? 'color:#2563eb;font-weight:bold' : 'color:#16a34a') : 'color:#ccc'}">${r.fba_inbound_working || 0}${r.fba_inbound_working_source === 'API' ? '<span style="font-size:9px;color:#2563eb;"> ⚡</span>' : ''}</td>
          <td>${r.effective_fba_stock ?? '-'}</td>
          <td>${r.days_of_supply ?? '-'}</td>
          <td>${r.reorder_point ?? '-'}</td>
          <td>${r.raw_needed ?? '-'}</td>
          <td>${r.target_days ?? '-'}</td>
          <td>${r.units_sold_7d ?? '-'}</td>
          <td>${r.units_sold_30d ?? '-'}</td>
          <td>${r.non_fba_sales_7d ?? '-'}</td>
          <td style="${(r.non_fba_sales_30d || 0) > 0 ? 'font-weight:bold;color:#7c3aed' : ''}">${r.non_fba_sales_30d ?? '-'}</td>
          <td style="font-weight:bold;${hasStock ? 'color:#16a34a' : 'color:#999'}">${r.warehouse_qty}</td>
          <td style="color:#2563eb;font-weight:bold">${r.warehouse_available ?? '-'}</td>
          <td style="${(r.non_fba_reserve || 0) > 0 ? 'font-weight:bold;color:#dc2626' : 'color:#999'}">${r.non_fba_reserve ?? '-'}</td>
          <td class="rec-qty">${r.recommended_qty ?? '-'}</td>
          <td class="rec-qty" style="font-size:11px;color:#666;">${r.adjusted_qty ?? '-'}</td>
          <td>${alertsHtml}</td>
        </tr>`;
      }).join('');
    }

    function onNewCheckChange(cb) {
      if (cb.checked) newCheckedSkus.add(cb.dataset.sku);
      else newCheckedSkus.delete(cb.dataset.sku);
    }

    async function hideNewProductChecked() {
      const msgEl = document.getElementById('newActionMsg');
      if (newCheckedSkus.size === 0) {
        msgEl.textContent = 'チェックされた商品がありません';
        msgEl.style.color = '#d97706';
        return;
      }
      try {
        const res = await fetch(`${BASE}/api/new-product-hidden`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ skus: [...newCheckedSkus] }),
        });
        const d = await res.json();
        msgEl.textContent = `${d.count}件を非表示にしました`;
        msgEl.style.color = '#16a34a';
        newCheckedSkus.clear();
        await updateNewProductList();
      } catch(e) {
        msgEl.textContent = 'エラー: ' + e.message;
        msgEl.style.color = '#dc2626';
      }
    }

    async function unhideNewProduct(sku) {
      try {
        await fetch(`${BASE}/api/new-product-hidden/${encodeURIComponent(sku)}`, { method: 'DELETE' });
        newHiddenSet.delete(sku);
        newProductData = newProductData.map(r =>
          r.amazon_sku === sku ? { ...r, is_hidden: false } : r
        );
        document.getElementById('newHiddenCount').textContent = `(${newHiddenSet.size}件)`;
        filterNewList();
      } catch(e) { /* ignore */ }
    }

    function addNewProductToShip() {
      const msgEl = document.getElementById('newActionMsg');
      if (newCheckedSkus.size === 0) {
        msgEl.textContent = 'チェックされた商品がありません';
        msgEl.style.color = '#d97706';
        return;
      }

      let addedCount = 0;
      let alreadyCount = 0;
      for (const sku of newCheckedSkus) {
        // 既に納品推奨にあるか確認
        const existing = recData.find(r => r.amazon_sku === sku);
        const existsInManual = manualItems.find(m => m.amazon_sku === sku);

        if (existing && existing.recommended_qty > 0) {
          alreadyCount++;
          continue;
        }
        if (existsInManual) {
          alreadyCount++;
          continue;
        }

        // 新規商品データから情報を取得
        const newProd = newProductData.find(r => r.amazon_sku === sku);

        if (existing) {
          existing.recommended_qty = 0;
          existing.adjusted_qty = 0;
          existing._manual = true;
          existing._fromNewProduct = true;
          addedCount++;
        } else {
          const item = {
            amazon_sku: sku,
            asin: newProd?.asin || '',
            product_name: newProd?.product_name || '(新規商品から追加)',
            ne_code: newProd?.ne_code || '',
            fnsku: newProd?.fnsku || '',
            set_components: newProd?.set_components || null,
            is_set: newProd?.is_set || false,
            fba_available: newProd?.fba_available ?? '-',
            fba_inbound_working: newProd?.fba_inbound_working ?? 0,
            fba_inbound_working_source: newProd?.fba_inbound_working_source || '',
            effective_fba_stock: newProd?.effective_fba_stock ?? '-',
            days_of_supply: newProd?.days_of_supply ?? '-',
            reorder_point: newProd?.reorder_point ?? '-',
            raw_needed: newProd?.raw_needed ?? '-',
            target_days: newProd?.target_days ?? '-',
            units_sold_7d: newProd?.units_sold_7d ?? '-',
            units_sold_30d: newProd?.units_sold_30d ?? '-',
            non_fba_sales_7d: newProd?.non_fba_sales_7d || 0,
            non_fba_sales_30d: newProd?.non_fba_sales_30d || 0,
            warehouse_raw: newProd?.warehouse_qty || 0,
            warehouse_available: newProd?.warehouse_qty || 0,
            recommended_qty: 0,
            adjusted_qty: 0,
            urgency_score: newProd?.urgency_score ?? 0,
            alerts: newProd?.alerts || [],
            _manual: true,
            _fromNewProduct: true,
          };
          manualItems.push(item);
          addedCount++;
        }
      }

      // チェックをクリア
      newCheckedSkus.clear();

      // メッセージ
      let msg = '';
      if (addedCount > 0) msg += `${addedCount}件を納品推奨に追加しました（数量0 → 手動入力してください）`;
      if (alreadyCount > 0) msg += `${alreadyCount > 0 && addedCount > 0 ? '、' : ''}${alreadyCount}件は既に納品推奨済みです`;
      msgEl.textContent = msg;
      msgEl.style.color = addedCount > 0 ? '#16a34a' : '#d97706';

      // リスト更新
      updateRecSummary();
      filterRecList();
      updateNewProductList();

      // 追加があれば納品推奨タブに切り替え
      if (addedCount > 0) {
        document.getElementById('recSection').style.display = '';
        setTimeout(() => switchTab('ship'), 500);
      }
    }

    // ===== ステップ制御 =====
    const stepCompleted = [false, false, false, false]; // Step 1~4

    function completeStep(n) {
      stepCompleted[n - 1] = true;
      const badge = document.getElementById('stepBadge' + n);
      const status = document.getElementById('stepStatus' + n);
      if (badge) { badge.classList.remove('active'); badge.classList.add('done'); badge.textContent = '✓ Step ' + n; }
      if (status) { status.classList.add('done'); status.textContent = '完了'; }

      // 次のステップをアンロック
      if (n < 4) {
        const nextBadge = document.getElementById('stepBadge' + (n + 1));
        if (nextBadge) { nextBadge.classList.add('active'); }
      }
      if (n === 1) {
        const csvLabel = document.getElementById('btnCsvLabel');
        csvLabel.style.opacity = '1';
        csvLabel.style.pointerEvents = 'auto';
      } else if (n === 2) {
        document.getElementById('btnSyncSku').disabled = false;
      } else if (n === 3) {
        document.getElementById('btnCalc').disabled = false;
      }
    }

    // 初期状態: Step 1 をアクティブに
    document.getElementById('stepBadge1').classList.add('active');

    // ===== FNSKUだけ選択 =====
    function selectOnlyFnsku() {
      const input = document.getElementById('excludeFnsku').value.trim();
      if (!input) { alert('FNSKUを入力してください'); return; }
      const fnskuList = input.split(/[,\s\n]+/).map(s => s.trim()).filter(Boolean);
      const fnskuSet = new Set(fnskuList);

      // まず全チェックを外す
      document.querySelectorAll('.rec-check:checked').forEach(cb => {
        cb.checked = false;
      });
      selectedSkus.clear();

      // FNSKU一致するSKUだけチェック
      let selected = 0;
      document.querySelectorAll('.rec-check').forEach(cb => {
        const sku = cb.dataset.sku;
        const rec = recData.find(r => r.amazon_sku === sku) || manualItems.find(m => m.amazon_sku === sku);
        if (rec && rec.fnsku && fnskuSet.has(rec.fnsku)) {
          cb.checked = true;
          selectedSkus.add(sku);
          selected++;
        }
      });
      updateSelectedCount();
      if (selected > 0) {
        log(`FNSKU選択: ${selected}件をチェックしました（他は全て解除）`);
      } else {
        alert('入力されたFNSKUに一致する商品がありませんでした');
      }
    }

    // ===== FNSKU除外 =====
    function excludeFnskuFromSelection() {
      const input = document.getElementById('excludeFnsku').value.trim();
      if (!input) { alert('FNSKUを入力してください'); return; }
      const fnskuList = input.split(/[,\s\n]+/).map(s => s.trim()).filter(Boolean);
      const fnskuSet = new Set(fnskuList);
      let removed = 0;
      // デバッグ: recDataのFNSKU保持状況
      const withFnsku = recData.filter(r => r.fnsku);
      console.log(`[FNSKU除外] recData: ${recData.length}件, fnsku有り: ${withFnsku.length}件`);
      console.log(`[FNSKU除外] 入力FNSKU:`, [...fnskuSet]);
      if (withFnsku.length > 0) {
        console.log(`[FNSKU除外] recDataサンプル:`, withFnsku.slice(0, 3).map(r => ({ sku: r.amazon_sku, fnsku: r.fnsku })));
      }
      document.querySelectorAll('.rec-check:checked').forEach(cb => {
        const sku = cb.dataset.sku;
        const rec = recData.find(r => r.amazon_sku === sku) || manualItems.find(m => m.amazon_sku === sku);
        if (rec && rec.fnsku && fnskuSet.has(rec.fnsku)) {
          cb.checked = false;
          selectedSkus.delete(sku);
          removed++;
        }
      });
      updateSelectedCount();
      if (removed > 0) {
        log(`FNSKU除外: ${removed}件のチェックを外しました`);
      } else {
        log(`FNSKU除外失敗: recData ${recData.length}件中 fnsku有り ${withFnsku.length}件。入力: ${[...fnskuSet].join(', ')}`);
        alert('入力されたFNSKUに一致するチェック済み商品はありませんでした');
      }
    }

    // ===== 納品Excel出力 =====
    async function exportManifestExcel() {
      const checkedItems = [];
      document.querySelectorAll('.rec-check:checked').forEach(cb => {
        const sku = cb.dataset.sku;
        const qtyInput = document.querySelector(`.ship-qty-input[data-sku="${sku}"]`);
        const qty = parseInt(qtyInput?.value) || 0;
        if (qty <= 0) return;
        const item = recData.find(r => r.amazon_sku === sku) || manualItems.find(m => m.amazon_sku === sku);
        checkedItems.push({
          amazon_sku: sku,
          ship_qty: qty,
          expiry_date: item?.expiry_date || '',
        });
      });

      if (checkedItems.length === 0) {
        alert('チェック済みで数量が入力されている商品がありません。');
        return;
      }

      log(`納品Excel出力: ${checkedItems.length} SKU`);

      try {
        const res = await fetch(`${BASE}/api/export-manifest`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ items: checkedItems }),
        });
        if (!res.ok) {
          const err = await res.json();
          alert('Excel出力エラー: ' + (err.error || '不明なエラー'));
          return;
        }
        const blob = await res.blob();
        const url = URL.createObjectURL(blob);
        const a = document.createElement('a');
        a.href = url;
        a.download = `FBA_Manifest_${new Date().toISOString().slice(0,10)}.xlsx`;
        a.click();
        URL.revokeObjectURL(url);
        log(`Excel出力完了: ${checkedItems.length} SKU`);
      } catch (e) {
        alert('Excel出力エラー: ' + e.message);
      }
    }

    // ===== 納品プラン作成 =====
    async function createInboundPlanAction() {
      // チェック済みのSKUを収集
      const checkedItems = [];
      document.querySelectorAll('.rec-check:checked').forEach(cb => {
        const sku = cb.dataset.sku;
        const qtyInput = document.querySelector(`.ship-qty-input[data-sku="${sku}"]`);
        const qty = parseInt(qtyInput?.value) || 0;
        if (qty <= 0) return; // 数量0は除外
        const item = recData.find(r => r.amazon_sku === sku) || manualItems.find(m => m.amazon_sku === sku);
        checkedItems.push({
          amazon_sku: sku,
          ship_qty: qty,
          product_name: item?.product_name || sku,
          asin: item?.asin || '',
          expiry_date: item?.expiry_date || '',
        });
      });

      if (checkedItems.length === 0) {
        alert('チェック済みで数量が入力されている商品がありません。');
        return;
      }

      // 数量0のチェック済みを警告
      let zeroQtySkus = [];
      document.querySelectorAll('.rec-check:checked').forEach(cb => {
        const sku = cb.dataset.sku;
        const qtyInput = document.querySelector(`.ship-qty-input[data-sku="${sku}"]`);
        const qty = parseInt(qtyInput?.value) || 0;
        if (qty <= 0) zeroQtySkus.push(sku);
      });

      let confirmMsg = `${checkedItems.length} SKU（合計 ${checkedItems.reduce((s, i) => s + i.ship_qty, 0).toLocaleString()} 個）で納品プランを作成します。`;
      if (zeroQtySkus.length > 0) {
        confirmMsg += `\n\n※ 数量0の ${zeroQtySkus.length} SKUは除外されます。`;
      }
      confirmMsg += '\n\nよろしいですか？';
      if (!confirm(confirmMsg)) return;

      // 作成中モーダル表示
      showInboundModal('creating', { totalItems: checkedItems.length });
      log(`納品プラン作成中... ${checkedItems.length} SKU`);

      try {
        const res = await fetch(`${BASE}/api/create-inbound-plan`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ items: checkedItems }),
        });
        let d = await res.json();

        if (d.error) {
          showInboundModal('error', { error: d.message || d.error });
          log('納品プラン作成エラー: ' + (d.message || d.error));
          return;
        }

        // ジョブ方式: jobIdが返ってきたらポーリング
        if (d.jobId) {
          log(`納品プラン作成ジョブ開始...`);
          const jobResult = await pollJob(d.jobId, {
            intervalMs: 2000,
            maxWaitMs: 120000,
            onProgress: (sec) => log(`納品プラン作成中... (${sec}秒経過)`),
          });
          if (jobResult.error) {
            showInboundModal('error', { error: jobResult.message || jobResult.error });
            log('納品プラン作成エラー: ' + (jobResult.message || jobResult.error));
            return;
          }
          d = jobResult.result || jobResult;
        }

        if (d.success) {
          showInboundModal('success', d);
          const planUrl2 = `https://sellercentral-japan.amazon.com/fba/sendtoamazon/confirm_content_step?wf=${d.inboundPlanId}`;
          log(`納品プラン作成成功: <a href="${planUrl2}" target="_blank" style="color:#2563eb;">Seller Centralで開く ↗</a> (プランID: ${d.inboundPlanId})`);
          // 成功したSKUにフラグを立てる
          for (const item of checkedItems) {
            const rec = recData.find(r => r.amazon_sku === item.amazon_sku);
            if (rec) rec._planCreated = true;
          }
          filterRecList();
        } else {
          // FAILED — エラー詳細を表示
          showInboundModal('failed', { ...d, items: checkedItems });
          log(`納品プラン作成失敗: ${d.problems?.length || 0} 件のエラー`);
          // エラーSKUにアラートを追加
          if (d.problems) {
            for (const p of d.problems) {
              const rec = recData.find(r => r.amazon_sku === p.msku);
              if (rec && rec.alerts) {
                rec.alerts.push({ type: 'plan_error', level: 3, message: `プランエラー: ${p.message || p.code}` });
              }
            }
            filterRecList();
          }
        }
      } catch (e) {
        showInboundModal('error', { error: e.message });
        log('納品プラン作成エラー: ' + e.message);
      }
    }

    // エラーSKUを除いて再作成
    async function retryWithoutErrors(errorSkus) {
      const errorSet = new Set(errorSkus);
      // エラーSKUのチェックを外す
      document.querySelectorAll('.rec-check:checked').forEach(cb => {
        if (errorSet.has(cb.dataset.sku)) {
          cb.checked = false;
          selectedSkus.delete(cb.dataset.sku);
        }
      });
      updateSelectedCount();
      // モーダルを閉じる
      closeInboundModal();
      // 再作成
      await createInboundPlanAction();
    }

    // NG商品調査→除外→再作成（フロントエンドから1件ずつチェック）
    async function investigateAndRetry() {
      const progEl = document.getElementById('investigateProgress');
      const checkedSkus = [];
      document.querySelectorAll('.rec-check:checked').forEach(cb => checkedSkus.push(cb.dataset.sku));

      const itemsToCheck = checkedSkus.map(sku => {
        const rec = recData.find(r => r.amazon_sku === sku) || manualItems.find(m => m.amazon_sku === sku);
        return { sku, asin: rec?.asin || '', name: rec?.product_name || '' };
      }).filter(i => i.asin);

      if (!itemsToCheck.length) { alert('ASINのある商品がありません'); return; }

      const ngSkus = [];
      for (let i = 0; i < itemsToCheck.length; i++) {
        const item = itemsToCheck[i];
        if (progEl) progEl.textContent = `${i + 1}/${itemsToCheck.length} チェック中...`;
        try {
          const r = await fetch(`${BASE}/api/eligibility/check-one?asin=${encodeURIComponent(item.asin)}&msku=${encodeURIComponent(item.sku)}`);
          const d = await r.json();
          if (!d.is_eligible) {
            ngSkus.push(item.sku);
            log(`⛔ NG: ${item.name || item.sku}`);
          }
        } catch {}
      }
      if (progEl) progEl.textContent = '';

      if (!ngSkus.length) {
        alert('Eligibility APIではNG商品を特定できませんでした。\nSeller Centralで確認してください。');
        return;
      }

      log(`NG ${ngSkus.length}件を除外して再作成: ${ngSkus.join(', ')}`);
      const ngSet = new Set(ngSkus);
      document.querySelectorAll('.rec-check:checked').forEach(cb => {
        if (ngSet.has(cb.dataset.sku)) { cb.checked = false; selectedSkus.delete(cb.dataset.sku); }
      });
      updateSelectedCount();
      closeInboundModal();
      await createInboundPlanAction();
    }

    // FBA_INBエラーコードの日本語翻訳
    const FBA_ERROR_JP = {
      'FBA_INB_0004': '危険物（Hazmat）として規制されている商品',
      'FBA_INB_0006': '危険物審査中（Hazmat情報が未入力）',
      'FBA_INB_0076': 'この商品はFBAで取扱不可',
      'FBA_INB_0086': '出品停止中の商品',
      'FBA_INB_0095': '要期限管理商品の期限情報不備',
      'FBA_INB_0098': '使用不可のFNSKU',
      'FBA_INB_0120': '有効期限が短すぎる（FBA受入基準未満）',
      'FBA_INB_0154': 'リコール対象商品',
      'FBA_INB_0180': '有効期限の入力が必要（要期限管理商品）',
      'FBA_INB_0182': 'Prep（梱包準備）の分類情報が未設定',
      'FBA_INB_0342': '製造元バーコードが使用不可',
    };

    function translateError(code, message) {
      const jp = FBA_ERROR_JP[code];
      if (jp) return jp;
      // 英語メッセージの簡易翻訳
      if (message?.includes('Expiration date required')) return '有効期限の入力が必要（要期限管理商品）';
      if (message?.includes('dangerous good')) return '危険物として規制されている商品';
      if (message?.includes('prepOwner')) return 'Prep設定エラー';
      return message || code || '不明なエラー';
    }

