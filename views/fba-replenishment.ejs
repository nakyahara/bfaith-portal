    // ===== 仮確定タブ =====
    let provisionalData = [];

    async function moveToProvisional() {
      const checkedItems = [];
      document.querySelectorAll('.rec-check:checked').forEach(cb => {
        const sku = cb.dataset.sku;
        const rec = recData.find(r => r.amazon_sku === sku) || manualItems.find(m => m.amazon_sku === sku);
        if (!rec) return;
        const qtyInput = document.querySelector(`.ship-qty-input[data-sku="${sku}"]`);
        const qty = parseInt(qtyInput?.value) || rec.recommended_qty || 0;
        checkedItems.push({
          amazon_sku: rec.amazon_sku,
          product_name: rec.product_name || '',
          fnsku: rec.fnsku || '',
          ship_qty: qty,
          fba_available: rec.fba_available || 0,
          units_sold_7d: rec.units_sold_7d || 0,
          units_sold_30d: rec.units_sold_30d || 0,
          warehouse_raw: rec.warehouse_raw || 0,
          recommended_qty: rec.recommended_qty || 0,
          urgency_score: rec.urgency_score || 0,
          set_components: rec.set_components || '',
          asin: rec.asin || '',
          expiry_date: rec.expiry_date || '',
        });
      });

      if (checkedItems.length === 0) {
        alert('商品を選択してください');
        return;
      }

      // 既存の仮確定データがあるか確認
      let existingCount = 0;
      try {
        const pRes = await fetch(`${BASE}/api/provisional`);
        const pData = await pRes.json();
        existingCount = (pData.items || []).length;
      } catch(e) { /* ignore */ }

      const msg = existingCount > 0
        ? `${checkedItems.length}件を仮確定に追加します（既存${existingCount}件は保持）。納品推奨のチェックはリセットされます。よろしいですか？`
        : `${checkedItems.length}件を仮確定に移動します。納品推奨のチェックはリセットされます。よろしいですか？`;
      if (!confirm(msg)) return;

      try {
        // マージAPI（既存データを保持しつつ追加・更新）
        const res = await fetch(`${BASE}/api/provisional/merge`, {
          method: 'POST',
          headers: {'Content-Type': 'application/json'},
          body: JSON.stringify({items: checkedItems}),
        });
        const d = await res.json();
        if (d.error) { alert('エラー: ' + d.error); return; }

        document.querySelectorAll('.rec-check:checked').forEach(cb => cb.checked = false);
        selectedSkus.clear();
        Object.keys(shipQtyMap).forEach(k => delete shipQtyMap[k]);
        updateSelectedCount();

        await loadProvisionalData();
        switchTab('provisional');
        const mergeMsg = existingCount > 0
          ? `${checkedItems.length}件を追加しました（合計${d.total}件）`
          : `仮確定に${checkedItems.length}件移動しました`;
        log(mergeMsg);
      } catch(e) {
        alert('エラー: ' + e.message);
      }
    }

