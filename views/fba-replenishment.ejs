        tbody.innerHTML = '<tr><td colspan="13" style="text-align:center;padding:24px;color:#888;">仮確定商品はありません。納品推奨タブで商品を選択して「仮確定に移動」してください。</td></tr>';
        return;
      }
      tbody.innerHTML = provisionalData.map((item, i) => {
        const urgColor = (item.urgency_score || 0) >= 80 ? '#dc2626' : (item.urgency_score || 0) >= 40 ? '#d97706' : '#666';
        return `<tr>
          <td style="text-align:center;"><input type="checkbox" class="prov-check" data-sku="${item.amazon_sku}" checked></td>
          <td style="text-align:center;">${i+1}</td>
          <td style="color:${urgColor};font-weight:bold;text-align:center;">${(item.urgency_score||0).toFixed(1)}</td>
          <td style="font-size:11px;">${item.amazon_sku}</td>
          <td style="max-width:200px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;" title="${(item.product_name||'').replace(/"/g,'&quot;')}">${item.product_name||''}</td>
          <td style="font-size:11px;">${item.set_components||''}</td>
          <td style="text-align:right;">${item.fba_available||0}</td>
          <td style="text-align:right;">${item.units_sold_7d||0}</td>
          <td style="text-align:right;">${item.units_sold_30d||0}</td>
          <td style="text-align:right;">${item.warehouse_raw||0}</td>
          <td style="text-align:right;">${item.recommended_qty||0}</td>
          <td style="text-align:center;background:#e0f2fe;">
            <input type="number" class="prov-qty-input" data-sku="${item.amazon_sku}" value="${item.ship_qty||0}" min="0" style="width:60px;text-align:center;border:1px solid #93c5fd;border-radius:4px;padding:2px 4px;font-size:13px;font-weight:bold;color:#1e40af;" onchange="updateProvQty('${item.amazon_sku}', this.value)">
          </td>
          <td style="text-align:center;">
            <button onclick="removeProvItem('${item.amazon_sku}')" style="background:none;border:none;color:#dc2626;cursor:pointer;font-size:16px;" title="削除">✕</button>
          </td>
