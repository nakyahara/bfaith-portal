            </div>
            ${problems.length > 0 ? `
              <h4 style="margin:0 0 8px;">エラー詳細</h4>
              <div style="max-height:200px;overflow-y:auto;">
                <table style="width:100%;border-collapse:collapse;">
                  <tr style="background:#f3f4f6;"><th style="padding:4px 8px;border:1px solid #e5e7eb;font-size:11px;">SKU</th><th style="padding:4px 8px;border:1px solid #e5e7eb;font-size:11px;">商品名</th><th style="padding:4px 8px;border:1px solid #e5e7eb;font-size:11px;">コード</th><th style="padding:4px 8px;border:1px solid #e5e7eb;font-size:11px;">理由</th></tr>
                  ${problemsHtml}
