      try {
        const res = await fetch(`${BASE}/api/export-ne-csv`, {
          method: 'POST',
          headers: {'Content-Type': 'application/json'},
          body: JSON.stringify({items: allItems}),
        });
        if (!res.ok) {
          const err = await res.json().catch(() => ({}));
          if (err.warnings && err.warnings.length > 0) {
            err.warnings.forEach(w => log(`NE CSV警告: ${w}`));
          }
          alert('エラー: ' + (err.error || 'CSV出力に失敗'));
          return;
        }
        const blob = await res.blob();
        const url = URL.createObjectURL(blob);
        const a = document.createElement('a');
        a.href = url;
        a.download = `hanyo-jyuchu_invoice_${new Date().toISOString().slice(0,10)}.csv`;
        a.click();
        URL.revokeObjectURL(url);
        log(`NE受注CSV出力: ${allItems.length} SKU → NE商品コードに変換済み`);
      } catch(e) { alert('エラー: ' + e.message); }
    }

    // ===== ピッキングリスト(試験) =====
    async function fetchPickingList() {
      const planId = document.getElementById('pickingPlanId').value.trim();
      if (!planId) { alert('プランIDを入力してください'); return; }
      const statusEl = document.getElementById('pickingStatus');
      const resultsEl = document.getElementById('pickingResults');
      statusEl.textContent = '取得中...';
      statusEl.style.color = '#2563eb';
      resultsEl.innerHTML = '';

      try {
        const res = await fetch(`${BASE}/api/picking-list/${encodeURIComponent(planId)}`);
        const d = await res.json();
        if (d.error) { statusEl.textContent = 'エラー: ' + d.error; statusEl.style.color = '#dc2626'; return; }

        statusEl.textContent = `${d.shipments.length}件のshipment取得完了`;
        statusEl.style.color = '#16a34a';

        let html = '';
        for (const shipment of d.shipments) {
          const totalQty = shipment.items.reduce((s, i) => s + (i.quantity || 0), 0);
          html += `<div style="margin-bottom:16px; border:1px solid #d1d5db; border-radius:8px; overflow:hidden;">`;
          html += `<div style="background:#f3f4f6; padding:8px 12px; font-weight:bold; font-size:13px;">`;
          html += `Shipment: ${shipment.shipmentId} — ${shipment.destination || '不明'} — ${shipment.items.length} SKU / ${totalQty} 個 — ${shipment.status}`;
          html += `</div>`;
          html += `<div class="table-wrap" style="max-height:400px;"><table class="data-table" style="font-size:12px;"><thead><tr>`;
          html += `<th>#</th><th>SKU</th><th>FNSKU</th><th>ASIN</th><th>商品名</th><th>NE商品コード</th><th>数量</th><th>有効期限</th><th>ラベル</th><th>Prep</th>`;
          html += `</tr></thead><tbody>`;
          shipment.items.forEach((item, i) => {
            html += `<tr>`;
            html += `<td>${i+1}</td>`;
            html += `<td style="font-size:11px;">${item.msku}</td>`;
            html += `<td style="font-size:11px;">${item.fnsku}</td>`;
            html += `<td style="font-size:11px;">${item.asin}</td>`;
            html += `<td style="max-width:200px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;" title="${item.product_name}">${item.product_name}</td>`;
            html += `<td style="font-size:11px;">${item.ne_code}</td>`;
            html += `<td style="text-align:right;font-weight:bold;">${item.quantity}</td>`;
            html += `<td style="font-size:11px;">${item.expiration || ''}</td>`;
            html += `<td style="font-size:11px;">${item.labelOwner}</td>`;
            html += `<td style="font-size:11px;">${item.prepOwner}</td>`;
            html += `</tr>`;
          });
          html += `</tbody></table></div></div>`;
        }
        resultsEl.innerHTML = html;
      } catch(e) {
        statusEl.textContent = 'エラー: ' + e.message;
        statusEl.style.color = '#dc2626';
      }
    }

    function provCheckAll() {
      document.querySelectorAll('.prov-check').forEach(cb => cb.checked = true);
    }
    function provUncheckAll() {
      document.querySelectorAll('.prov-check').forEach(cb => cb.checked = false);
    }

    async function clearProvisionalConfirm() {
      if (!confirm('仮確定データをクリアしますか？')) return;
      try {
        await fetch(`${BASE}/api/provisional`, {method: 'DELETE'});
        provisionalData = [];
        renderProvisionalTable();
        updateProvisionalSummary({});
        document.getElementById('provisionalTabCount').style.display = 'none';
        log('仮確定データをクリアしました');
      } catch(e) { alert('エラー: ' + e.message); }
    }

    // ===== 自動ロード =====
    async function autoLoad() {
      await loadStatus();

      // ドラフトがあるか確認
      const draft = await checkDraftOnLoad();

      // 仮確定データを読み込み
      await loadProvisionalData();

      // ドラフトがなくてもデータがあれば自動で推奨リスト生成
      if (!draft) {
        try {
          const statusRes = await fetch(`${BASE}/api/status`);
          const status = await statusRes.json();
          if (status.snapshotCount > 0 && status.mappingCount > 0) {
            log('データが存在するため自動で推奨リスト生成中...');
            const res = await fetch(`${BASE}/api/recommendations?debug=1`);
            const d = await res.json();
            if (!d.error && d.items && d.items.length > 0) {
              recData = d.items || [];
              recMeta = d;
              manualItems = [];
              log(`自動生成完了: 全${d.total_skus}SKU / 推奨${d.recommended_skus}SKU`);
              document.getElementById('recSection').style.display = '';
              updateRecSummary();
              filterRecList();
              updateOrderList();
              await updateStockoutList();
              await loadWarehouseSummaryMap();
              await updateNewProductList();
            }
          }
        } catch(e) { /* ignore */ }
      }
    }

    // 初期ロード
    autoLoad();
  </script>
</body>
</html>
