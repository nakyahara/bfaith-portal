    async function createPlanFromProvisional() {
      const checkedItems = [];
      document.querySelectorAll('.prov-check:checked').forEach(cb => {
        const sku = cb.dataset.sku;
        const qtyInput = document.querySelector(`.prov-qty-input[data-sku="${sku}"]`);
        const item = provisionalData.find(i => i.amazon_sku === sku);
        if (item) {
          checkedItems.push({
            sku: sku,
            qty: parseInt(qtyInput?.value) || item.ship_qty || 0,
          });
        }
      });
      if (checkedItems.length === 0) { alert('商品を選択してください'); return; }
      if (!confirm(`${checkedItems.length}件で納品プランを作成します。よろしいですか？`)) return;

      const btn = event.target;
      btn.disabled = true;
      btn.innerHTML = '<span class="spinner"></span>作成中...';
      log(`仮確定から納品プラン作成: ${checkedItems.length} SKU`);

      try {
        const res = await fetch(`${BASE}/api/create-inbound-plan`, {
          method: 'POST',
          headers: {'Content-Type': 'application/json'},
          body: JSON.stringify({items: checkedItems.map(i => {
          const item = provisionalData.find(p => p.amazon_sku === i.sku);
          return {
            amazon_sku: i.sku,
            ship_qty: i.qty,
            product_name: item?.product_name || i.sku,
            asin: item?.asin || '',
            expiry_date: item?.expiry_date || '',
          };
        })}),
        });
        let d = await res.json();
        if (d.error) {
          log('エラー: ' + (d.message || d.error));
          if (d.details) log('詳細: ' + JSON.stringify(d.details));
          if (d.errorSkus && d.errorSkus.length > 0) {
            log('エラーSKU: ' + d.errorSkus.map(s => `${s.sku} (${s.name || ''})`).join(', '));
          }
          return;
        }
        // ジョブ方式対応
        if (d.jobId) {
          log('納品プラン作成ジョブ開始...');
          const jobResult = await pollJob(d.jobId, { intervalMs: 2000, maxWaitMs: 120000 });
          if (jobResult.error) { log('エラー: ' + (jobResult.message || jobResult.error)); return; }
          d = jobResult.result || jobResult;
        }
        const planUrl = `https://sellercentral-japan.amazon.com/fba/sendtoamazon/confirm_content_step?wf=${d.inboundPlanId}`;
        log(`納品プラン作成成功! <a href="${planUrl}" target="_blank" style="color:#2563eb;">Seller Centralで開く ↗</a> (プランID: ${d.inboundPlanId})`);
        if (d.shipments) {
          d.shipments.forEach(s => log(`  出荷先: ${s.destination} / ${s.skuCount} SKU / ${s.totalQty} 個`));
        }
      } catch(e) { log('エラー: ' + e.message); }
      finally {
        btn.disabled = false;
        btn.textContent = '📦 納品プラン作成';
      }
    }

    // ===== NE受注CSV出力 =====
