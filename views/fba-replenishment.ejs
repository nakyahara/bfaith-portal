    function applyDraft(draft) {
      if (!draft || !draft.items) return;

      // 欠品・新規商品・手動追加アイテムを復元
      for (const di of draft.items) {
        if (di.from_stockout || di.from_new_product || di.is_manual) {
          const existing = recData.find(r => r.amazon_sku === di.amazon_sku);
          if (existing) {
            existing._manual = true;
            if (di.from_stockout) existing._fromStockout = true;
            if (di.from_new_product) existing._fromNewProduct = true;
            existing.recommended_qty = existing.recommended_qty || 0;
          } else if (!manualItems.find(m => m.amazon_sku === di.amazon_sku)) {
            // recDataにないアイテム（新規商品や手動追加）をmanualItemsに復元
            const mapping = skuMappingMap[di.amazon_sku];
            const snap = snapshotData.find(s => s.amazon_sku === di.amazon_sku);
            manualItems.push({
              amazon_sku: di.amazon_sku,
              asin: mapping?.asin || snap?.asin || '',
              product_name: mapping?.product_name || snap?.product_name || '(ドラフトから復元)',
              ne_code: mapping?.ne_code || '',
              fnsku: mapping?.fnsku || '',
              set_components: mapping?.set_components || null,
              is_set: mapping?.is_set ? true : false,
              fba_available: snap?.fba_available ?? '-',
              fba_inbound_working: snap?.fba_inbound_working ?? 0,
              fba_inbound_working_source: '',
              effective_fba_stock: snap?.effective_fba_stock ?? '-',
              days_of_supply: snap?.days_of_supply ?? '-',
              reorder_point: '-',
              raw_needed: '-',
              target_days: '-',
              units_sold_7d: snap?.units_sold_7d ?? '-',
              units_sold_30d: snap?.units_sold_30d ?? '-',
              non_fba_sales_7d: mapping?.non_fba_sales_7d || 0,
              non_fba_sales_30d: mapping?.non_fba_sales_30d || 0,
              warehouse_raw: '-',
              warehouse_available: '-',
              recommended_qty: di.ship_qty || 0,
              adjusted_qty: di.ship_qty || 0,
              urgency_score: 0,
              alerts: [],
              _manual: true,
              _fromStockout: di.from_stockout || false,
              _fromNewProduct: di.from_new_product || false,
            });
          }
        }
      }

      // チェック状態と数量を復元
      selectedSkus.clear();
      for (const di of draft.items) {
        if (di.checked) selectedSkus.add(di.amazon_sku);
        if (di.ship_qty > 0) {
          const item = recData.find(r => r.amazon_sku === di.amazon_sku) || manualItems.find(m => m.amazon_sku === di.amazon_sku);
          const defaultQty = item?.adjusted_qty || 0;
          if (di.ship_qty !== defaultQty) {
            shipQtyMap[di.amazon_sku] = di.ship_qty;
          }
        }
      }
    }

