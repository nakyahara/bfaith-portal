    let currentSettings = {};

    async function openSettings() {
      try {
        const res = await fetch(`${BASE}/api/settings`);
        currentSettings = await res.json();
      } catch(e) { currentSettings = {}; }

      let html = `<div class="settings-overlay" onclick="closeSettings()"></div>
        <div class="settings-modal" id="settingsModal">
          <span class="settings-close" onclick="closeSettings()">&times;</span>
          <h3 style="margin:0 0 16px;">⚙ 計算ロジック設定</h3>
          <div class="legend-box" style="margin-bottom:16px; padding:10px; background:#f8f9fa; border-radius:6px;">
            <span style="font-size:12px; font-weight:bold; margin-right:8px;">テーブル色の意味:</span>
            <div class="legend-item"><div class="legend-color" style="background:#fee2e2;"></div>緊急度80以上（早急に送る）</div>
            <div class="legend-item"><div class="legend-color" style="background:#fef3c7;"></div>緊急度40〜79（近いうちに送る）</div>
            <div class="legend-item"><div class="legend-color" style="background:white;"></div>緊急度40未満（余裕あり）</div>
          </div>`;

      for (const g of SETTINGS_SCHEMA) {
        html += `<div class="settings-group"><h4>${g.group}</h4>`;
        if (g.desc) html += `<p class="group-desc">${g.desc}</p>`;
        for (const item of g.items) {
          const val = currentSettings[item.key] || '';
          html += `<div class="setting-row">
            <label>${item.label}<span class="setting-desc">${item.desc}</span></label>
            <input type="text" value="${val}" data-key="${item.key}" onchange="saveSetting(this)">
            <span style="font-size:12px;color:#666;min-width:50px;">${item.unit}</span>
            <span class="setting-saved" id="saved_${item.key}">保存済</span>
          </div>`;
        }
        html += `</div>`;
      }
      html += `<p style="font-size:11px;color:#999;margin-top:12px;">※ 設定変更後は「推奨リスト生成」を再実行してください。</p></div>`;

      const div = document.createElement('div');
      div.id = 'settingsContainer';
      div.innerHTML = html;
      document.body.appendChild(div);
    }

    function openManual() {
      const html = `<div class="settings-overlay" onclick="closeManual()"></div>
        <div class="settings-modal" id="manualModal" style="max-width:850px;">
          <span class="settings-close" onclick="closeManual()">&times;</span>
          <h3 style="margin:0 0 16px;">📖 FBA在庫補充 計算マニュアル</h3>

          <div class="settings-group">
            <h4>計算フロー全体像</h4>
            <pre style="font-size:12px;line-height:1.6;background:#f8f9fa;padding:12px;border-radius:6px;overflow-x:auto;">
Step1: 実質FBA在庫の算出
  = 販売可能 + 輸送中 + 受領中 + 準備中(7日超は除外)

Step2: 日販の算出
  FBA日販 = FBA30日売上 ÷ 30
  他CH日販 = 他CH30日売上 ÷ 30（NEデータ）

Step3: 発注点・目標日数の決定
  30日売上で回転率を分類 → サイズで目標日数を分岐
  発注点は日数で設定し、個数換算(日数×FBA日販)で比較

Step4: 発注点チェック（ゲートキーパー）
  FBA在庫 < 発注点(個数) → 推奨に上がる
  FBA在庫 ≧ 発注点(個数) → 補充不要

Step5: 必要補充数
  = ceil(FBA日販 × 目標日数) - 実質FBA在庫

Step6: 倉庫在庫の按分
  倉庫在庫 = Yロケ以外の在庫のみ（Yロケは出庫禁止のため除外）
  FBA比率 = FBA日販 ÷ (FBA日販 + 他CH実効日販)
  FBA用在庫 = 倉庫在庫 × FBA比率
  ※ 他CH売上の欠品補正あり（60日最大値 or 入荷日推定）

Step7: 推奨数 = min(必要補充数, FBA用在庫)
  ※ 最低出荷カバー日数に満たない場合は除外
  ※ 有効期限管理商品はこのフィルターを無効化（古い期限の滞留防止）

Step7.5: 有効期限チェック
  FBAは同一商品で期限違いを同梱不可
  → 引当優先の最古期限のみ送れる → 推奨数を制限

Step8: 数量補正（2段階）
  A. 5個単位丸め（20個超の場合）
  B. ロケーション補正（±10%以内でロケ在庫区切りに寄せ）

Step9: 緊急度スコア算出
Step10: アラート判定</pre>
          </div>

          <div class="settings-group">
            <h4>回転率の分類と設定値</h4>
            <table style="width:100%;font-size:12px;border-collapse:collapse;">
              <tr style="background:#f3f4f6;"><th style="padding:6px;border:1px solid #e5e7eb;">分類</th><th style="padding:6px;border:1px solid #e5e7eb;">条件</th><th style="padding:6px;border:1px solid #e5e7eb;">発注点</th><th style="padding:6px;border:1px solid #e5e7eb;">目標日数(小型)</th><th style="padding:6px;border:1px solid #e5e7eb;">目標日数(大型/不明)</th></tr>
              <tr><td style="padding:6px;border:1px solid #e5e7eb;">高回転</td><td style="padding:6px;border:1px solid #e5e7eb;">月100個超</td><td style="padding:6px;border:1px solid #e5e7eb;">21日</td><td style="padding:6px;border:1px solid #e5e7eb;">40日</td><td style="padding:6px;border:1px solid #e5e7eb;">30日</td></tr>
              <tr><td style="padding:6px;border:1px solid #e5e7eb;">中回転</td><td style="padding:6px;border:1px solid #e5e7eb;">月20〜100個</td><td style="padding:6px;border:1px solid #e5e7eb;">21日</td><td style="padding:6px;border:1px solid #e5e7eb;" colspan="2">35日</td></tr>
              <tr><td style="padding:6px;border:1px solid #e5e7eb;">低回転</td><td style="padding:6px;border:1px solid #e5e7eb;">月20個未満</td><td style="padding:6px;border:1px solid #e5e7eb;">14日</td><td style="padding:6px;border:1px solid #e5e7eb;">180日</td><td style="padding:6px;border:1px solid #e5e7eb;">90日</td></tr>
              <tr><td style="padding:6px;border:1px solid #e5e7eb;">売上0</td><td style="padding:6px;border:1px solid #e5e7eb;">月0個</td><td style="padding:6px;border:1px solid #e5e7eb;" colspan="3">推奨に上がらない（手動追加で対応）</td></tr>
            </table>
            <p style="font-size:11px;color:#666;margin-top:8px;">※ 7日売上が10個以上の場合は低回転でも中回転扱い（低在庫手数料リスク回避）<br>※ サイズ不明(0cm³)は大型扱い（保管料リスク回避）</p>
          </div>

          <div class="settings-group">
            <h4>フィルターと補正</h4>
            <table style="width:100%;font-size:12px;border-collapse:collapse;">
              <tr style="background:#f3f4f6;"><th style="padding:6px;border:1px solid #e5e7eb;">機能</th><th style="padding:6px;border:1px solid #e5e7eb;">条件</th><th style="padding:6px;border:1px solid #e5e7eb;">効果</th></tr>
              <tr><td style="padding:6px;border:1px solid #e5e7eb;">最低出荷カバー日数</td><td style="padding:6px;border:1px solid #e5e7eb;">推奨数÷日販 < 7日</td><td style="padding:6px;border:1px solid #e5e7eb;">除外（少量の二度手間防止）<br>FBA在庫0でも1日分未満は除外<br><strong>※ 有効期限管理商品は無効</strong>（古い期限が滞留→廃棄リスク防止）</td></tr>
              <tr><td style="padding:6px;border:1px solid #e5e7eb;">有効期限チェック</td><td style="padding:6px;border:1px solid #e5e7eb;">複数期限がある場合</td><td style="padding:6px;border:1px solid #e5e7eb;">最古期限の在庫のみ送れる（FBAルール）<br>翌日は送った分が減り次の期限が引き当たる</td></tr>
              <tr><td style="padding:6px;border:1px solid #e5e7eb;">5個単位丸め</td><td style="padding:6px;border:1px solid #e5e7eb;">推奨数 > 20個</td><td style="padding:6px;border:1px solid #e5e7eb;">5の倍数に丸め（ピッキングの数えやすさ）</td></tr>
              <tr><td style="padding:6px;border:1px solid #e5e7eb;">ロケーション補正</td><td style="padding:6px;border:1px solid #e5e7eb;">丸め後 ±10%以内</td><td style="padding:6px;border:1px solid #e5e7eb;">引当優先ロケの累積在庫に寄せる（棚まるごとピック可能に）</td></tr>
            </table>
          </div>

          <div class="settings-group">
            <h4>Yロケ（出庫禁止ロケーション）</h4>
            <p style="font-size:13px;line-height:1.7;margin:0;">
              Yロケは<strong>出庫禁止ロケーション</strong>です。外部の福祉施設（いろは）に商品を預けて作業（セット組み・検品等）を行い、作業完了後にYロケ以外の通常ロケーションに戻してから出荷可能になります。
            </p>
            <table style="width:100%;font-size:12px;border-collapse:collapse;margin-top:8px;">
              <tr style="background:#f3f4f6;"><th style="padding:6px;border:1px solid #e5e7eb;">項目</th><th style="padding:6px;border:1px solid #e5e7eb;">扱い</th></tr>
              <tr><td style="padding:6px;border:1px solid #e5e7eb;">倉庫在庫（計算対象）</td><td style="padding:6px;border:1px solid #e5e7eb;">Yロケ<strong>以外</strong>の在庫のみ。FBA推奨・他CH按分すべてにこの値を使用。</td></tr>
              <tr><td style="padding:6px;border:1px solid #e5e7eb;">Yロケ在庫</td><td style="padding:6px;border:1px solid #e5e7eb;">参考値として別途記録。計算には使わない。作業完了後にCSV再アップロードで通常在庫に反映される。</td></tr>
              <tr><td style="padding:6px;border:1px solid #e5e7eb;">判定条件</td><td style="padding:6px;border:1px solid #e5e7eb;">ブロック略称が「YYY」またはロケーションコードが「Y」始まり。</td></tr>
            </table>
          </div>

          <div class="settings-group">
            <h4>ロケーション引当順位</h4>
            <pre style="font-size:12px;line-height:1.6;background:#f8f9fa;padding:12px;border-radius:6px;">
第1優先: ロケ業務区分 =「卸し」
  → ブロック引当順（若い順）
    → ロケーションコード（若い順）
第2優先: ロケ業務区分 =「通販」
  → 同じくブロック引当順 → ロケ順

ロケ在庫を上から累積し、丸め後の±10%以内に
入る区切り点があれば、その数量に補正します。</pre>
          </div>

          <div class="settings-group">
            <h4>テーブルの色の意味</h4>
            <div class="legend-box">
              <div class="legend-item"><div class="legend-color" style="background:#fee2e2;"></div><strong>赤（緊急度80以上）</strong>：全部送る。一括チェックで選択。</div>
              <div class="legend-item"><div class="legend-color" style="background:#fef3c7;"></div><strong>黄（緊急度40〜79）</strong>：翌日回しOK。必要なものだけ個別チェック。</div>
              <div class="legend-item"><div class="legend-color" style="background:white;border:1px solid #ccc;"></div><strong>白（緊急度40未満）</strong>：余裕あり。</div>
            </div>
          </div>

          <div class="settings-group">
            <h4>運用フロー</h4>
            <ol style="font-size:13px;line-height:1.8;margin:0;padding-left:20px;">
              <li>SP-APIレポート取得 + ロジザードCSVアップロード</li>
              <li>「推奨リスト生成」をクリック</li>
              <li>サマリーで赤/黄のSKU数・数量を確認</li>
              <li>「🔴 緊急を全選択」で赤を一括チェック</li>
              <li>黄色を上から見て、必要なものだけ個別チェック</li>
              <li>選択中のSKU数・数量を確認して納品作業へ</li>
            </ol>
            <p style="font-size:11px;color:#666;margin-top:8px;">※ 初回は300+SKUが推奨に上がりますが、低回転商品に半年分を送ると2〜3週間で50〜80SKU/日に収束します。</p>
          </div>

          <div class="settings-group">
            <h4>緊急度スコアの計算</h4>
            <pre style="font-size:12px;line-height:1.6;background:#f8f9fa;padding:12px;border-radius:6px;">
基本スコア = max(0, 100 - (供給日数 × 100 / 40))
  → 供給日数0日=100点, 40日以上=0点

月商ウェイト = min(自社価格 × 30日売上 / 100,000, 5)
トレンド倍率 = (7日売上/7×30) / 30日売上（0.5〜3.0にクリップ）
手数料ブースト = 低在庫手数料発生中なら2倍

緊急度 = 基本 × (1 + 月商W × 0.2) × トレンド × 手数料ブースト</pre>
          </div>

          <div class="settings-group">
            <h4>アラート一覧</h4>
            <table style="width:100%;font-size:12px;border-collapse:collapse;">
              <tr style="background:#f3f4f6;"><th style="padding:6px;border:1px solid #e5e7eb;">アラート</th><th style="padding:6px;border:1px solid #e5e7eb;">条件</th></tr>
              <tr><td style="padding:6px;border:1px solid #e5e7eb;">カート価格下落</td><td style="padding:6px;border:1px solid #e5e7eb;">カート価格 < 自社価格（3段階）</td></tr>
              <tr><td style="padding:6px;border:1px solid #e5e7eb;">低在庫手数料</td><td style="padding:6px;border:1px solid #e5e7eb;">短期供給日数 < 14日</td></tr>
              <tr><td style="padding:6px;border:1px solid #e5e7eb;">過剰在庫</td><td style="padding:6px;border:1px solid #e5e7eb;">超過数量あり or 供給90日超</td></tr>
              <tr><td style="padding:6px;border:1px solid #e5e7eb;">送り漏れ</td><td style="padding:6px;border:1px solid #e5e7eb;">FBA在庫0 + BSR5000位以内 + 倉庫に在庫あり</td></tr>
              <tr><td style="padding:6px;border:1px solid #e5e7eb;">急上昇/急停止</td><td style="padding:6px;border:1px solid #e5e7eb;">7日→30日比が2倍超 or 7日間売上0</td></tr>
            </table>
          </div>
        </div>`;

      const div = document.createElement('div');
      div.id = 'manualContainer';
      div.innerHTML = html;
      document.body.appendChild(div);
    }

    function closeManual() {
      const c = document.getElementById('manualContainer');
      if (c) c.remove();
    }

    function closeSettings() {
      const c = document.getElementById('settingsContainer');
      if (c) c.remove();
    }

    async function saveSetting(input) {
      const key = input.dataset.key;
      const value = input.value.trim();
      try {
        await fetch(`${BASE}/api/settings`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ key, value })
        });
        const saved = document.getElementById('saved_' + key);
        if (saved) { saved.style.opacity = '1'; setTimeout(() => saved.style.opacity = '0', 2000); }
      } catch(e) { alert('設定保存エラー: ' + e.message); }
    }

    // ===== ステップ制御 =====
    const stepCompleted = [false, false, false, false]; // Step 1~4

    function completeStep(n) {
      stepCompleted[n - 1] = true;
      const badge = document.getElementById('stepBadge' + n);
      const status = document.getElementById('stepStatus' + n);
      if (badge) { badge.classList.remove('active'); badge.classList.add('done'); badge.textContent = '✓ Step ' + n; }
      if (status) { status.classList.add('done'); status.textContent = '完了'; }

      // 次のステップをアンロック
      if (n < 4) {
        const nextBadge = document.getElementById('stepBadge' + (n + 1));
        if (nextBadge) { nextBadge.classList.add('active'); }
      }
      if (n === 1) {
        const csvLabel = document.getElementById('btnCsvLabel');
        csvLabel.style.opacity = '1';
        csvLabel.style.pointerEvents = 'auto';
      } else if (n === 2) {
        document.getElementById('btnSyncSku').disabled = false;
      } else if (n === 3) {
        document.getElementById('btnCalc').disabled = false;
      }
    }

    // 初期状態: Step 1 をアクティブに
    document.getElementById('stepBadge1').classList.add('active');

    // 初期ロード
    loadStatus();
  </script>
</body>
</html>
