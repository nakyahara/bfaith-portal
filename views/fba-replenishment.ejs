    async function updateProvQty(sku, qty) {
      try {
        await fetch(`${BASE}/api/provisional/${encodeURIComponent(sku)}/qty`, {
          method: 'PATCH',
          headers: {'Content-Type': 'application/json'},
          body: JSON.stringify({qty: parseInt(qty) || 0}),
        });
        const item = provisionalData.find(i => i.amazon_sku === sku);
        if (item) item.ship_qty = parseInt(qty) || 0;
        updateProvisionalSummary({});
      } catch(e) { console.error(e); }
    }

    async function removeProvItem(sku) {
      const item = provisionalData.find(i => i.amazon_sku === sku);
      const name = item?.product_name || sku;
      if (!confirm(`この商品を仮確定リストから削除しますか？\n\n${name}\n(${sku})`)) return;
      try {
        await fetch(`${BASE}/api/provisional/${encodeURIComponent(sku)}`, {method: 'DELETE'});
        log(`仮確定から削除: ${name} (${sku})`);
        provisionalData = provisionalData.filter(i => i.amazon_sku !== sku);
        renderProvisionalTable();
        updateProvisionalSummary({});
        const countEl = document.getElementById('provisionalTabCount');
        if (provisionalData.length > 0) {
          countEl.textContent = provisionalData.length;
        } else {
          countEl.style.display = 'none';
        }
      } catch(e) { console.error(e); }
    }

    function excludeFnskuFromProvisional() {
      const input = document.getElementById('provExcludeFnsku').value.trim();
      if (!input) { alert('FNSKUを入力してください'); return; }
      const fnskuList = input.split(/[,\s\n]+/).map(s => s.trim()).filter(Boolean);
      const fnskuSet = new Set(fnskuList);
      let removed = 0;
      document.querySelectorAll('.prov-check:checked').forEach(cb => {
        const sku = cb.dataset.sku;
        const item = provisionalData.find(i => i.amazon_sku === sku);
        if (item && item.fnsku && fnskuSet.has(item.fnsku)) {
          cb.checked = false;
          removed++;
        }
      });
      if (removed > 0) {
        log(`仮確定FNSKU除外: ${removed}件のチェックを外しました`);
      } else {
        alert('入力されたFNSKUに一致するチェック済み商品はありませんでした');
      }
    }

    function selectOnlyFnskuProvisional() {
      const input = document.getElementById('provExcludeFnsku').value.trim();
      if (!input) { alert('FNSKUを入力してください'); return; }
      const fnskuList = input.split(/[,\s\n]+/).map(s => s.trim()).filter(Boolean);
      const fnskuSet = new Set(fnskuList);
      document.querySelectorAll('.prov-check').forEach(cb => cb.checked = false);
      let selected = 0;
      document.querySelectorAll('.prov-check').forEach(cb => {
        const sku = cb.dataset.sku;
