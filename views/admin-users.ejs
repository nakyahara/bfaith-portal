<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>ユーザー管理 - B-Faith Portal</title>
  <link rel="stylesheet" href="/style.css">
  <style>
    .apps-checkboxes {
      display: flex;
      flex-direction: column;
      gap: 6px;
    }
    .apps-checkboxes label {
      display: flex;
      align-items: center;
      gap: 6px;
      font-size: 13px;
      cursor: pointer;
      white-space: nowrap;
    }
    .apps-checkboxes input[type="checkbox"] {
      width: 16px;
      height: 16px;
      cursor: pointer;
    }
    .btn-perm-save {
      margin-top: 8px;
      padding: 4px 12px;
      font-size: 12px;
      background: #2563eb;
      color: #fff;
      border: none;
      border-radius: 4px;
      cursor: pointer;
    }
    .btn-perm-save:hover {
      background: #1d4ed8;
    }
    .perm-saved {
      display: inline-block;
      color: #16a34a;
      font-size: 12px;
      margin-left: 8px;
      opacity: 0;
      transition: opacity 0.3s;
    }
    .perm-saved.show {
      opacity: 1;
    }
    .add-apps-checkboxes {
      display: flex;
      flex-wrap: wrap;
      gap: 12px;
      margin-top: 4px;
    }
    .add-apps-checkboxes label {
      display: flex;
      align-items: center;
      gap: 4px;
      font-size: 13px;
      cursor: pointer;
    }
  </style>
</head>
<body>
  <header class="portal-header">
    <div class="header-left">
      <a href="/" class="back-link">← ダッシュボード</a>
      <h1>ユーザー管理</h1>
    </div>
    <div class="header-right">
      <span class="user-name"><%= displayName %></span>
      <a href="/logout" class="btn-logout">ログアウト</a>
    </div>
  </header>

  <main class="admin-page">
    <% if (success) { %>
      <div class="success-msg"><%= success %></div>
    <% } %>
    <% if (error) { %>
      <div class="error-msg"><%= error %></div>
    <% } %>

    <!-- ユーザー追加フォーム -->
    <div class="form-card" style="margin-bottom: 32px;">
      <h2 class="section-title">ユーザー追加</h2>
      <form method="POST" action="/admin/users/add">
        <div class="form-row">
          <div class="form-group">
            <label for="email">メールアドレス</label>
            <input type="email" id="email" name="email" required placeholder="user@b-faith.biz">
          </div>
          <div class="form-group">
            <label for="displayName">表示名</label>
            <input type="text" id="displayName" name="displayName" required placeholder="山田 太郎">
          </div>
        </div>
        <div class="form-row">
          <div class="form-group">
            <label for="password">初期パスワード（6文字以上）</label>
            <input type="password" id="password" name="password" required minlength="6">
          </div>
          <div class="form-group">
            <label for="role">権限</label>
            <select id="role" name="role" class="form-select">
              <option value="user">一般ユーザー</option>
              <option value="admin">管理者</option>
            </select>
          </div>
        </div>
        <div class="form-group">
          <label>アクセス可能アプリ</label>
          <div class="add-apps-checkboxes">
            <% apps.forEach(app => { %>
              <label>
                <input type="checkbox" name="allowedApps" value="<%= app.id %>">
                <%= app.icon %> <%= app.name %>
              </label>
            <% }) %>
          </div>
        </div>
        <button type="submit" class="btn-save" style="margin-top: 12px;">追加</button>
      </form>
    </div>

    <!-- ユーザー一覧 -->
    <h2 class="section-title">登録ユーザー一覧</h2>
    <table class="permissions-table">
      <thead>
        <tr>
          <th>表示名</th>
          <th>メールアドレス</th>
          <th>権限</th>
          <th>アクセス可能アプリ</th>
          <th>操作</th>
        </tr>
      </thead>
      <tbody>
        <% users.forEach(user => { %>
          <tr>
            <td><strong><%= user.displayName %></strong></td>
            <td><%= user.email %></td>
            <td><span class="role-badge role-<%= user.role %>"><%= user.role === 'admin' ? '管理者' : '一般' %></span></td>
            <td>
              <% if (user.role === 'admin') { %>
                <span class="role-badge role-admin">全アプリ</span>
              <% } else { %>
                <form class="perm-form" data-email="<%= user.email %>">
                  <div class="apps-checkboxes">
                    <% apps.forEach(app => { %>
                      <label>
                        <input type="checkbox" value="<%= app.id %>"
                          <%= (Array.isArray(user.allowedApps) && user.allowedApps.includes(app.id)) ? 'checked' : '' %>
                        >
                        <%= app.icon %> <%= app.name %>
                      </label>
                    <% }) %>
                  </div>
                  <button type="submit" class="btn-perm-save">保存</button>
                  <span class="perm-saved">保存しました</span>
                </form>
              <% } %>
            </td>
            <td>
              <% if (user.email !== username) { %>
                <div class="action-buttons">
                  <!-- パスワードリセット -->
                  <form method="POST" action="/admin/users/reset-password" class="inline-form">
                    <input type="hidden" name="email" value="<%= user.email %>">
                    <input type="password" name="newPassword" placeholder="新パスワード" minlength="6" required class="inline-input">
                    <button type="submit" class="btn-small btn-reset">PW変更</button>
                  </form>
                  <!-- 削除 -->
                  <form method="POST" action="/admin/users/delete" class="inline-form"
                    onsubmit="return confirm('<%= user.displayName %> を削除しますか？')">
                    <input type="hidden" name="email" value="<%= user.email %>">
                    <button type="submit" class="btn-small btn-danger">削除</button>
                  </form>
                </div>
              <% } else { %>
                <span style="color: #999; font-size: 13px;">自分自身</span>
              <% } %>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </main>

  <script>
    document.querySelectorAll('.perm-form').forEach(form => {
      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        const email = form.dataset.email;
        const checked = [...form.querySelectorAll('input[type="checkbox"]:checked')].map(cb => cb.value);
        try {
          const res = await fetch('/admin/users/permissions', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ email, allowedApps: checked }),
          });
          if (res.ok) {
            const msg = form.querySelector('.perm-saved');
            msg.classList.add('show');
            setTimeout(() => msg.classList.remove('show'), 2000);
          }
        } catch (err) {
          alert('保存に失敗しました');
        }
      });
    });
  </script>
</body>
</html>
